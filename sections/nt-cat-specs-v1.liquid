<style>
:root{
  --ts-xl:2.2rem; --navy:#111111; --red:#0188CC; --ink:#111111; --body:#333333; --muted:#666666;
  --cream:#ffffff; --cream-deep:#f5f5f5; --line:rgba(0,0,0,.07);
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:#fff;color:#333;line-height:1.6;}

.cat-specs{padding:88px 48px;background:var(--cream)}
.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;}
.sec-h em{font-style:italic;color:var(--red)}
.sec-sub{font-family:var(--fb);font-size:1rem;color:var(--muted);line-height:1.65;max-width:580px;margin:0 auto;}

.specs-inner{max-width:980px;margin:0 auto}
.specs-grid{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--line);box-shadow:0 14px 36px rgba(0,0,0,.06);}
.spec-row{display:grid;grid-template-columns:240px 1fr;border-bottom:1px solid var(--line);padding:22px 28px;align-items:center;}
.spec-row:last-child{border-bottom:none}
.spec-label{font-family:var(--fb);font-size:.78rem;font-weight:700;color:var(--navy);letter-spacing:.06em;text-transform:uppercase;}
.spec-val{font-family:var(--fb);font-size:.94rem;color:var(--body);line-height:1.55;}

@media(max-width:680px){
  .cat-specs{padding:64px 22px}
  .spec-row{grid-template-columns:1fr;gap:4px;padding:18px 20px}
  .spec-label{font-size:.7rem;color:var(--muted)}
}
</style>

<section class="cat-specs">
  <div class="sec-head">
    <span class="sec-label">Build Specs</span>
    <h2 class="sec-h">Engineered to <em>Last</em></h2>
    <p class="sec-sub">What goes into every sign that leaves our factory floor. UL-listed components, weather-rated materials, and the kind of craftsmanship a permit inspector signs off on the first time.</p>
  </div>
  <div class="specs-inner">
    <div class="specs-grid">
      <div class="spec-row"><div class="spec-label">Letter Construction</div><div class="spec-val">0.040" or 0.063" aluminum returns with welded back panels</div></div>
      <div class="spec-row"><div class="spec-label">Letter Faces</div><div class="spec-val">Acrylic, polycarbonate, brushed aluminum, polished stainless, or composite</div></div>
      <div class="spec-row"><div class="spec-label">Illumination</div><div class="spec-val">UL-listed low-voltage LED modules (6500K cool white, 3000K warm white, RGB available)</div></div>
      <div class="spec-row"><div class="spec-label">Power Supply</div><div class="spec-val">UL-recognized class 2 transformer with surge protection</div></div>
      <div class="spec-row"><div class="spec-label">Color Options</div><div class="spec-val">Any RAL, PMS, or custom color match (factory-finish, automotive-grade)</div></div>
      <div class="spec-row"><div class="spec-label">Mounting Options</div><div class="spec-val">Direct stud, raceway, or backboard mount</div></div>
      <div class="spec-row"><div class="spec-label">Warranty</div><div class="spec-val">5 years on LEDs, electrical components, and structural integrity</div></div>
      <div class="spec-row"><div class="spec-label">Lead Time</div><div class="spec-val">10–14 business days from approved mockup to ship</div></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NT Cat Specs",
  "presets": [
    {
      "name": "NT Cat Specs"
    }
  ]
}
{% endschema %}