<style>
:root{
  --ts-2xl:clamp(2.4rem,5vw,4.4rem); --navy:#111111; --navy-deep:#0a0a0a; --gold:#0188CC;
  --cream:#ffffff; --cream-deep:#f5f5f5; --ink:#111111; --muted:#666666;
  --gold-line:rgba(1,136,204,.24); --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:var(--cream);color:#333;line-height:1.6;}

.cat-hero{position:relative;padding:150px 48px 0;background:linear-gradient(180deg,var(--navy-deep) 0%,var(--navy) 100%);color:#fff;overflow:hidden;}
.cat-hero::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 20%,rgba(1,136,204,.12) 0%,transparent 65%),radial-gradient(ellipse 40% 30% at 50% 100%,rgba(1,136,204,.08) 0%,transparent 70%);}
.cat-hero-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.1fr 1fr;gap:64px;align-items:center;position:relative;z-index:1;padding-bottom:80px;}
.cat-breadcrumb{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.74rem;color:rgba(255,255,255,.5);margin-bottom:22px;letter-spacing:.06em;}
.cat-breadcrumb a{color:rgba(255,255,255,.7);transition:color .2s;text-decoration:none;}
.cat-breadcrumb a:hover{color:var(--gold)}
.cat-breadcrumb svg{width:10px;height:10px;stroke:rgba(255,255,255,.4);stroke-width:2.5;fill:none}
.cat-breadcrumb .current{color:var(--gold)}
.cat-hero h1{font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;line-height:1.02;letter-spacing:-.02em;margin-bottom:20px;font-weight:400;}
.cat-hero h1 em{font-style:italic;color:var(--gold)}
.cat-hero-desc{font-family:var(--fb);font-size:1.06rem;line-height:1.7;color:rgba(255,255,255,.78);margin-bottom:28px;max-width:540px;}
.cat-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:34px}
.cat-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(1,136,204,.08);border:1px solid rgba(1,136,204,.32);color:var(--gold);padding:7px 13px;border-radius:100px;font-family:var(--fb);font-size:.78rem;font-weight:600;}
.cat-pill svg{width:13px;height:13px;stroke:var(--gold);stroke-width:2.5;fill:none}
.cat-hero-ctas{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);text-decoration:none;}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none}
.btn-ghost{background:transparent;color:#fff;font-family:var(--fb);font-size:.95rem;font-weight:600;padding:15px 26px;border-radius:10px;border:1.5px solid rgba(255,255,255,.32);display:inline-flex;align-items:center;gap:10px;text-decoration:none;}
.btn-ghost:hover{background:rgba(255,255,255,.08)}
.btn-ghost svg{width:14px;height:14px;stroke:#fff;stroke-width:2;fill:none}
.cat-hero-visual{position:relative;aspect-ratio:4/5;border-radius:18px;overflow:hidden;box-shadow:0 30px 70px rgba(0,0,0,.5);}
.cat-hero-visual img{width:100%;height:100%;object-fit:cover}
.cat-hero-visual::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.6) 100%);}

.trust-bar-merged{background:rgba(0,0,0,.55);backdrop-filter:blur(8px);border-top:1px solid rgba(1,136,204,.22);padding:22px 48px;margin:auto -48px 0;position:relative;z-index:2;width:calc(100% + 96px);}
.trust-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:16px;align-items:center;}
.trust-item{display:flex;align-items:center;justify-content:center;gap:10px;color:rgba(255,255,255,.88);font-family:var(--fb);font-size:.82rem;text-align:left;}
.trust-item svg{width:18px;height:18px;stroke:var(--gold);stroke-width:2;fill:none;flex-shrink:0}
.trust-item strong{color:#fff;font-weight:700;margin-right:3px}

@media(max-width:980px){
  .cat-hero{padding:130px 22px 0}
  .cat-hero-inner{grid-template-columns:1fr;gap:36px;padding-bottom:56px}
  .cat-hero-visual{max-width:420px;margin:0 auto;width:100%;aspect-ratio:5/4}
  .trust-bar-merged{margin:auto -22px 0;width:calc(100% + 44px);padding:18px 22px}
  .trust-inner{grid-template-columns:repeat(2,1fr);gap:14px 18px}
}
</style>

<section class="cat-hero">
  <div class="cat-hero-inner">
    <div class="cat-hero-text">
      <div class="cat-breadcrumb">
        <a href="/">Home</a>
        <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/pages/sign-types">Sign Types</a>
        <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        <span class="current">Storefront signs</span>
      </div>
      <h1>Storefront signs <em>Built to Glow.</em></h1>
      <p class="cat-hero-desc">The most-ordered custom storefront sign in America. Hand-fabricated backlit channel letters with custom LED illumination, available as halo-lit, front lit backlit, and reverse-lit acrylic storefront signs. Engineered for permits, built for the long haul.</p>
      <div class="cat-pills">
        <span class="cat-pill"><svg viewBox="0 0 24 24"><path d="M20 7L9 18l-5-5"/></svg>UL-listed components</span>
        <span class="cat-pill"><svg viewBox="0 0 24 24"><path d="M20 7L9 18l-5-5"/></svg>Front-lit, halo, or combo</span>
        <span class="cat-pill"><svg viewBox="0 0 24 24"><path d="M20 7L9 18l-5-5"/></svg>Day & night visibility</span>
      </div>
      <div class="cat-hero-ctas">
        <a href="/pages/get-a-quote" class="btn-primary">Get Your Free Mockup <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
        <a href="/pages/sign-types" class="btn-ghost">All Sign Types <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></a>
      </div>
    </div>
    <div class="cat-hero-visual">
      <img src="https://cdn.shopify.com/s/files/1/0598/2096/6023/files/a41f50aee39a3c269c600156808215e7.jpg?v=1773827697" alt="Custom backlit channel letter signs installed on commercial storefront – signs.inc" loading="eager">
    </div>
  </div>

  <div class="trust-bar trust-bar-merged">
    <div class="trust-inner">
      <div class="trust-item"><svg viewBox="0 0 24 24"><path d="M12 2l3 7h7l-6 4.5L18 22l-6-4-6 4 2-8.5L2 9h7z"/></svg><span><strong>4.9/5</strong> from 450+ businesses</span></div>
      <div class="trust-item"><svg viewBox="0 0 24 24"><path d="M3 12h18M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/><circle cx="12" cy="12" r="10"/></svg><span>Installed in <strong>all 50 states</strong></span></div>
      <div class="trust-item"><svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg><span><strong>5-year</strong> warranty</span></div>
      <div class="trust-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg><span>Free mockup in <strong>2 hours</strong></span></div>
      <div class="trust-item"><svg viewBox="0 0 24 24"><path d="M20 7L9 18l-5-5"/></svg><span><strong>UL listed</strong> components</span></div>
    </div>
  </div>
</section>

{% schema %}
