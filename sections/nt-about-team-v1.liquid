<style>
:root{
  --ts-xl:2.2rem; --navy:#111111; --gold:#0188CC; --red:#0188CC;
  --cream-deep:#f5f5f5; --ink:#111111; --muted:#666666; --line:rgba(0,0,0,.07);
  --gold-line:rgba(1,136,204,.24);
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:#fff;color:#333;line-height:1.6;}

.team-section{padding:88px 48px;background:var(--cream-deep)}
.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;}
.sec-h em{font-style:italic;color:var(--red)}
.sec-sub{font-family:var(--fb);font-size:1rem;color:var(--muted);line-height:1.65;max-width:580px;margin:0 auto;}

.team-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:22px;}
.team-card{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--line);transition:transform .3s,box-shadow .3s,border-color .25s;}
.team-card:hover{transform:translateY(-4px);box-shadow:0 20px 40px rgba(0,0,0,.08);border-color:var(--gold-line);}
.team-photo{position:relative;aspect-ratio:4/5;overflow:hidden;background:linear-gradient(135deg,var(--navy) 0%,#1a1a1a 100%);}
.team-photo img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
.team-card:hover .team-photo img{transform:scale(1.04)}
.team-info{padding:22px 20px 24px}
.team-name{font-family:var(--fh);font-size:1.15rem;color:var(--ink);line-height:1.2;margin-bottom:4px;font-weight:400;}
.team-role{font-family:var(--fb);font-size:.76rem;color:var(--gold);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;}
.team-bio{font-family:var(--fb);font-size:.86rem;color:var(--muted);line-height:1.6;}

@media(max-width:980px){.team-section{padding:64px 22px}.team-grid{grid-template-columns:repeat(2,1fr);gap:16px}}
@media(max-width:480px){.team-grid{grid-template-columns:1fr;gap:14px}.team-photo{aspect-ratio:5/4}}
</style>

<section class="team-section">
  <div class="sec-head">
    <span class="sec-label">The People</span>
    <h2 class="sec-h">Meet the <em>Team</em></h2>
    <p class="sec-sub">The designers, fabricators and project managers behind every sign that leaves our shop.</p>
  </div>
  <div style="max-width:1180px;margin:0 auto 42px;border-radius:16px;overflow:hidden;box-shadow:0 18px 42px rgba(0,0,0,.10)">
    <img src="https://i.ibb.co/67Jvf6vD/TVt-Hf.jpg" alt="Signs INC team standing together in custom business sign manufacturing workshop – signs.inc" style="width:100%;height:auto;display:block;object-fit:cover;max-height:420px;object-position:center 30%" loading="lazy">
  </div>
  <div class="team-grid">
    <div class="team-card">
      <div class="team-photo"><img src="https://i.ibb.co/MDWX7SxT/hv-NJn.jpg" alt="Michael Kareem Founder – signs.inc"></div>
      <div class="team-info"><div class="team-name">Michael Kareem</div><div class="team-role">Founder &amp; Head of Production</div><p class="team-bio">Second-generation metal fabricator. Runs the production floor and personally signs off on every large-format job before it ships.</p></div>
    </div>
    <div class="team-card">
      <div class="team-photo"><img src="https://i.ibb.co/mF1ppncX/1ua-ES.jpg" alt="Sarah Rodriguez Lead Designer – signs.inc"></div>
      <div class="team-info"><div class="team-name">Sarah Rodriguez</div><div class="team-role">Lead Designer</div><p class="team-bio">12 years in sign design. Creates every mockup and works directly with clients on revisions until the layout, color and proportion are right.</p></div>
    </div>
    <div class="team-card">
      <div class="team-photo"><img src="https://i.ibb.co/Zz4SQMcw/Ar-Q6w.jpg" alt="James Thornton Install Operations Manager – signs.inc"></div>
      <div class="team-info"><div class="team-name">James Thornton</div><div class="team-role">Install Operations Manager</div><p class="team-bio">Manages our installer network across all 50 states. Coordinates permits, site surveys, scheduling and post-install follow-up on every job.</p></div>
    </div>
    <div class="team-card">
      <div class="team-photo"><img src="https://i.ibb.co/B2LNBQnz/itdi-A.jpg" alt="Aisha Noor Client Success Lead – signs.inc"></div>
      <div class="team-info"><div class="team-name">Aisha Noor</div><div class="team-role">Client Success Lead</div><p class="team-bio">Your first point of contact. Handles quoting, order tracking and makes sure every question gets answered the same day it comes in.</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NT About Team",
  "presets": [
    {
      "name": "NT About Team"
    }
  ]
}
{% endschema %}