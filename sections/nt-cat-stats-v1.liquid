<style>
:root{
  --navy:#111111; --gold:#0188CC; --cream-deep:#f5f5f5; --ink:#111111; --muted:#666666;
  --line2:rgba(0,0,0,.12); --gold-line:rgba(1,136,204,.24);
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:#fff;color:#333;line-height:1.6;}

.cat-stats{background:var(--cream-deep);padding:28px 48px;border-bottom:1px solid var(--line2);}
.cat-stats-inner{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.cat-stat{display:flex;align-items:center;gap:14px;}
.cat-stat-icon{width:42px;height:42px;border-radius:10px;background:#fff;border:1px solid var(--gold-line);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cat-stat-icon svg{width:18px;height:18px;stroke:var(--navy);stroke-width:2;fill:none}
.cat-stat-meta{display:flex;flex-direction:column;line-height:1.2}
.cat-stat-num{font-family:var(--fh);font-size:1.32rem;color:var(--ink);font-weight:400}
.cat-stat-lab{font-family:var(--fb);font-size:.74rem;color:var(--muted);margin-top:2px}

@media(max-width:880px){
  .cat-stats{padding:22px}
  .cat-stats-inner{grid-template-columns:1fr 1fr;gap:18px}
  .cat-stat-num{font-size:1.1rem}
}
</style>

<div class="cat-stats">
  <div class="cat-stats-inner">
    <div class="cat-stat">
      <div class="cat-stat-icon"><svg viewBox="0 0 24 24"><path d="M12 2l3 7h7l-6 4.5L18 22l-6-4-6 4 2-8.5L2 9h7z"/></svg></div>
      <div class="cat-stat-meta"><span class="cat-stat-num">Most Popular</span><span class="cat-stat-lab">Sign Type in US</span></div>
    </div>
    <div class="cat-stat">
      <div class="cat-stat-icon"><svg viewBox="0 0 24 24"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
      <div class="cat-stat-meta"><span class="cat-stat-num">$1,800+</span><span class="cat-stat-lab">Starting Price</span></div>
    </div>
    <div class="cat-stat">
      <div class="cat-stat-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
      <div class="cat-stat-meta"><span class="cat-stat-num">10-14 days</span><span class="cat-stat-lab">Production Time</span></div>
    </div>
    <div class="cat-stat">
      <div class="cat-stat-icon"><svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg></div>
      <div class="cat-stat-meta"><span class="cat-stat-num">5-Year</span><span class="cat-stat-lab">Warranty</span></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "NT Cat Stats",
  "presets": [
    {
      "name": "NT Cat Stats"
    }
  ]
}
{% endschema %}