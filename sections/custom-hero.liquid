{{ 'custom-hero.css' | asset_url | stylesheet_tag }}

<section class="custom-hero">
  <div class="page-width hero-wrapper">

    <div class="hero-content">

      <h1>{{ section.settings.heading }}</h1>

      <p>{{ section.settings.description }}</p>

      <div class="hero-buttons">

        {% if section.settings.shop_link != blank %}
          <a href="{{ section.settings.shop_link }}" class="btn-shop">
            {{ section.settings.shop_text }}
          </a>
        {% endif %}

        {% if section.settings.explore_link != blank %}
          <a href="{{ section.settings.explore_link }}" class="btn-explore">
            {{ section.settings.explore_text }}
          </a>
        {% endif %}

      </div>

    </div>

    <div class="hero-image">

      {% if section.settings.hero_image != blank %}
        <img
          src="{{ section.settings.hero_image | image_url }}"
          alt="Hero Image"
          width="650"
          height="650"
        >
      {% endif %}

    </div>

    <div class="dots">
      {% for i in (1..120) %}
        <span></span>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Hero Heading",
      "default": "Modern Interior Design Studio"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Donec vitae odio quis nisl dapibus malesuada. Nullam ac aliquet velit."
    },

    {
      "type": "text",
      "id": "shop_text",
      "label": "Shop Button Text",
      "default": "Shop Now"
    },

    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop Button Link"
    },

    {
      "type": "text",
      "id": "explore_text",
      "label": "Explore Button Text",
      "default": "Explore"
    },

    {
      "type": "url",
      "id": "explore_link",
      "label": "Explore Button Link"
    },

    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }

  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}