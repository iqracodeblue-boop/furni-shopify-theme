<style>
:root{
  --navy:#111111; --navy-deep:#0a0a0a; --gold:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:#fff;color:#333;line-height:1.6;}

.contact-mockup-cta{background:var(--navy-deep);padding:64px 48px;position:relative;overflow:hidden;}
.contact-mockup-cta::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 55% 100% at 0% 100%,rgba(1,136,204,.2) 0%,transparent 55%),radial-gradient(ellipse 40% 80% at 100% 0%,rgba(1,136,204,.1) 0%,transparent 55%);}
.contact-mockup-cta-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;position:relative;z-index:1;}
.contact-mockup-cta-text .sec-label{justify-content:flex-start;margin-bottom:10px;color:var(--gold)}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--gold);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--gold);}
.contact-mockup-cta-text .sec-label::before,.contact-mockup-cta-text .sec-label::after{background:var(--gold)}
.contact-mockup-cta-text h3{font-family:var(--fh);font-size:clamp(1.6rem,3vw,2.3rem);color:#fff;font-weight:400;margin-bottom:12px;line-height:1.12;}
.contact-mockup-cta-text h3 em{font-style:italic;color:var(--gold)}
.contact-mockup-cta-text p{font-family:var(--fb);font-size:.93rem;color:rgba(255,255,255,.58);line-height:1.65;max-width:480px;}
.contact-mockup-actions{display:flex;flex-direction:column;align-items:center;gap:16px;}
.btn-primary{background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;text-decoration:none;}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none}
.contact-mockup-note{font-family:var(--fb);font-size:.76rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:5px;}
.contact-mockup-note svg{width:12px;height:12px;fill:none;stroke:rgba(255,255,255,.4);stroke-width:2}

@media(max-width:768px){
  .contact-mockup-cta{padding:40px 20px}
  .contact-mockup-cta-inner{grid-template-columns:1fr;gap:20px}
  .contact-mockup-cta-text h3{font-size:1.5rem}
  .contact-mockup-cta-text p{font-size:.86rem}
  .contact-mockup-actions{align-items:flex-start}
  .contact-mockup-btn{width:100%;justify-content:center}
}
</style>

<section class="contact-mockup-cta">
  <div class="contact-mockup-cta-inner">
    <div class="contact-mockup-cta-text">
      <span class="sec-label">Free Mockup</span>
      <h3>Prefer to See It First? <em>Get a Free Mockup.</em></h3>
      <p>Send your logo and storefront photo. We will design a custom sign on your building and send it back in 2 hours. No commitment.</p>
    </div>
    <div class="contact-mockup-actions">
      <a href="/pages/get-a-quote" class="btn-primary contact-mockup-btn">
        Get Your Free Mockup
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <span class="contact-mockup-note">
        <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg>
        No obligation · 2-hour turnaround
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NT Contact CTA",
  "presets": [
    {
      "name": "NT Contact CTA"
    }
  ]
}
{% endschema %}