<style>
:root{
  --ts-2xs:.68rem; --ts-xs:.78rem; --ts-sm:.88rem; --ts-base:1rem; --ts-md:1.15rem;
  --ts-lg:1.5rem; --ts-xl:2.2rem; --ts-2xl:clamp(2.4rem,5vw,4.4rem);
  --navy:#111111; --navy-deep:#0a0a0a; --navy-light:#1a1a1a; --gold:#0188CC;
  --gold-deep:#0170a8; --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --red:#0188CC; --red-deep:#016da0; --cream:#ffffff; --cream-deep:#f5f5f5;
  --cream-warm:#fafafa; --ink:#111111; --body:#333333; --muted:#666666;
  --ghost:#999999; --line:rgba(0,0,0,.07); --line2:rgba(0,0,0,.12);
  --line3:rgba(0,0,0,.20); --card:#fff; --white:#fff; --star:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;overflow-x:clip}
@media(max-width:480px){html{font-size:100%}}
body{font-family:var(--fb);background:var(--cream);color:var(--body);-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-x:clip;max-width:100%;position:relative;min-height:100dvh;min-height:-webkit-fill-available;line-height:1.6;}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button{cursor:pointer;border:none;background:none;font-family:inherit}

/* Sign Types Page Specific CSS */
.page{display:none;min-height:100vh;max-width:100%;overflow-x:clip}
.page.active{display:block;animation:pgIn .42s cubic-bezier(.16,1,.3,1) both}
@keyframes pgIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}

.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--fb);font-size:.82rem;font-weight:700;
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--red);margin-bottom:16px;
}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{
  font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);
  line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;
}
.sec-h em{font-style:italic;color:var(--red);font-family:var(--fh)}
.sec-sub{
  font-family:var(--fb);font-size:1rem;color:var(--muted);
  line-height:1.65;max-width:580px;margin:0 auto;
}

.types-hero{
  position:relative;padding:160px 48px 80px;
  background:linear-gradient(180deg,var(--navy-deep) 0%,var(--navy) 100%);
  color:#fff;text-align:center;
}
.types-hero h1{
  font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;
  line-height:1.04;letter-spacing:-.02em;margin-bottom:18px;font-weight:400;
}
.types-hero h1 em{color:var(--gold);font-style:italic}
.types-hero p{
  font-family:var(--fb);font-size:1.08rem;
  color:rgba(255,255,255,.72);max-width:620px;margin:0 auto;line-height:1.65;
}
.types-list{padding:88px 48px;background:var(--cream);max-width:1280px;margin:0 auto}
.type-row{
  display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;
  margin-bottom:84px;
}
.type-row.reverse{direction:rtl}
.type-row.reverse > *{direction:ltr}
.type-row-img{
  position:relative;aspect-ratio:5/4;border-radius:16px;overflow:hidden;
  box-shadow:0 20px 50px rgba(0,0,0,.16);
}
.type-row-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s}
.type-row-img:hover img{transform:scale(1.05)}
.type-row-content .sec-label{justify-content:flex-start}
.type-row-content .sec-label::before,.type-row-content .sec-label::after{display:none}
.type-row-content h3{
  font-family:var(--fh);font-size:2rem;color:var(--ink);
  margin-bottom:14px;font-weight:400;line-height:1.15;letter-spacing:-.01em;
}
.type-row-content p{
  font-family:var(--fb);font-size:.98rem;color:var(--body);line-height:1.72;
  margin-bottom:20px;
}
.type-row-features{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
.type-row-features li{
  display:flex;align-items:flex-start;gap:10px;
  font-family:var(--fb);font-size:.9rem;color:var(--body);line-height:1.5;
}
.type-row-features li svg{
  width:18px;height:18px;stroke:var(--red);stroke-width:2.5;fill:none;flex-shrink:0;margin-top:2px;
}
.type-row-btn{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--fb);font-size:.86rem;font-weight:700;
  color:var(--navy);padding:13px 22px;
  border:1.5px solid var(--navy);border-radius:9px;
  transition:background .25s,color .25s,transform .2s;
}
.type-row-btn:hover{background:var(--navy);color:#fff;transform:translateY(-2px)}
.type-row-btn svg{width:13px;height:13px;stroke:currentColor;stroke-width:2.5;fill:none}

.final-cta{
  background:linear-gradient(180deg,var(--navy) 0%,var(--navy-deep) 100%);
  color:#fff;padding:104px 48px;
  position:relative;overflow:hidden;text-align:center;
}
.final-cta::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 50% at 0% 100%,rgba(1,136,204,.16) 0%,transparent 70%),radial-gradient(ellipse 60% 50% at 100% 0%,rgba(1,136,204,.10) 0%,transparent 65%);
}
.final-cta::after{
  content:"";position:absolute;top:0;left:50%;width:1px;height:60px;
  background:linear-gradient(180deg,var(--gold) 0%,transparent 100%);
  transform:translateX(-50%);
}
.final-inner{max-width:780px;margin:0 auto;position:relative;z-index:1}
.final-inner .sec-label{color:var(--gold);justify-content:center}
.final-inner .sec-label::before,.final-inner .sec-label::after{background:var(--gold)}
.final-inner h2{
  font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;
  line-height:1.04;letter-spacing:-.02em;margin-bottom:18px;font-weight:400;
}
.final-inner h2 em{font-style:italic;color:var(--gold)}
.final-inner p{
  font-family:var(--fb);font-size:1.08rem;line-height:1.6;
  color:rgba(255,255,255,.72);max-width:560px;margin:0 auto 36px;
}
.btn-primary{
  background:var(--gold);color:var(--navy);
  font-family:var(--fb);font-size:.95rem;font-weight:700;
  padding:16px 28px;border-radius:10px;
  display:inline-flex;align-items:center;gap:10px;
  transition:transform .2s,box-shadow .25s,background .25s;
  box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;
}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}

@media(max-width:880px){
  .types-hero{padding:130px 22px 60px}
  .types-list{padding:64px 22px}
  .type-row{grid-template-columns:1fr;gap:28px;margin-bottom:60px}
  .type-row.reverse{direction:ltr}
  .final-cta{padding:76px 24px}
}
</style>

<!-- SIGN TYPES PAGE HTML -->
