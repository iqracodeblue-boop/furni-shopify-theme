{% comment %} 
  Schema for customizer integration 
{% endcomment %}
{% schema %}
{
  "name": "Home Page",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Premium Custom Signage, Built to Last"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Custom Business Sign That Gets You Noticed"
    }
  ]
}
{% endschema %}

<div class="home-page-wrapper" id="nt-home-page">
  
  {% comment %} ===== HERO SECTION ===== {% endcomment %}
  <section class="hero-section" style="
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    padding: 120px 0 80px;
    position: relative;
    overflow: hidden;
  ">
    
    <!-- Background Pattern -->
    <div style="
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      opacity: 0.05;
      background-image: radial-gradient(circle at 20% 30%, white 1px, transparent 1px),
                        radial-gradient(circle at 80% 70%, white 1px, transparent 1px);
      background-size: 60px 60px;
    "></div>
    
    <div style="
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 40px;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    ">
      
      <!-- Hero Content -->
      <div style="color: white;">
        
        <!-- Badge -->
        <div style="
          display: inline-flex;
          align-items: center;
          gap: 10px;
          background: rgba(255, 107, 53, 0.15);
          border: 1px solid rgba(255, 107, 53, 0.3);
          padding: 10px 20px;
          border-radius: 50px;
          font-size: 14px;
          font-weight: 600;
          color: #FF6B35;
          margin-bottom: 25px;
        ">
          <i class="fas fa-star"></i>
          Trusted by 450+ Businesses Nationwide
        </div>
        
        <!-- Title -->
        <h1 style="
          font-family: 'Poppins', sans-serif;
          font-size: 56px;
          font-weight: 800;
          line-height: 1.15;
          margin-bottom: 25px;
        ">
          {{ section.settings.hero_title | default: 'Premium Custom Signage, Built to Last' }}
        </h1>
        
        <!-- Subtitle -->
        <p style="
          font-size: 19px;
          line-height: 1.7;
          margin-bottom: 35px;
          opacity: 0.85;
        ">
          {{ section.settings.subtitle | default: 'Custom business signs that get you noticed. From bold illuminated signage to refined interior displays – we engineer and build to UL standards.' }}
        </p>
        
        <!-- CTA Buttons -->
        <div style="display: flex; gap: 18px; flex-wrap: wrap;">
          <a href="{{ pages['get-a-quote'].url }}" style="
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 36px;
            background: #0066CC;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 15px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(0, 102, 204, 0.3);
          " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(0, 102, 204, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(0, 102, 204, 0.3)'">
            <i class="fas fa-magic"></i>
            Get Your Free Mockup
          </a>
          
          <a href="{{ pages['sign-categories'].url }}" style="
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 36px;
            background: transparent;
            color: white;
            text-decoration: none;
            border: 2px solid white;
            border-radius: 8px;
            font-weight: 700;
            font-size: 15px;
            transition: all 0.3s ease;
          " onmouseover="this.style.background='white'; this.style.color='#0066CC'" onmouseout="this.style.background='transparent'; this.color='white'">
            Browse Sign Types
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>
        
        <!-- Trust Badges -->
        <div style="
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 25px;
          margin-top: 45px;
        ">
          
          <div style="
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,0.08);
            padding: 18px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
          ">
            <div style="
              width: 48px;
              height: 48px;
              background: rgba(255,255,255,0.08);
              border-radius: 10px;
              display: flex;
              align-items: center;
              justify-content: center;
              font-size: 20px;
              color: #FF6B35;
            ">
              <i class="fas fa-star"></i>
            </div>
            <div>
              <h4 style="font-size: 17px; font-weight: 700; margin-bottom: 3px;">4.8/5 Rating</h4>
              <p style="font-size: 13px; opacity: 0.75;">From 450+ businesses</p>
            </div>
          </div>
          
          <div style="
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,0.08);
            padding: 18px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
          ">
            <div style="
              width: 48px;
              height: 48px;
              background: rgba(255,255,255,0.08);
              border-radius: 10px;
              display: flex;
              align-items: center;
              justify-content: center;
              font-size: 20px;
              color: #FF6B35;
            ">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <div>
              <h4 style="font-size: 17px; font-weight: 700; margin-bottom: 3px;">All 50 States</h4>
              <p style="font-size: 13px; opacity: 0.75;">Nationwide service</p>
            </div>
          </div>
          
          <div style="
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,0.08);
            padding: 18px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
          ">
            <div style="
              width: 48px;
              height: 48px;
              background: rgba(255,255,255,0.08);
              border-radius: 10px;
              display: flex;
              align-items: center;
              justify-content: center;
              font-size: 20px;
              color: #FF6B35;
            ">
              <i class="fas fa-shield-alt"></i>
            </div>
            <div>
              <h4 style="font-size: 17px; font-weight: 700; margin-bottom: 3px;">2-Year Warranty</h4>
              <p style="font-size: 13px; opacity: 0.75;">On all products</p>
            </div>
          </div>
          
        </div>
      </div>
      
      <!-- Hero Image -->
      <div>
        {% if section.settings.hero_image != blank %}
          <img src="{{ section.settings.hero_image | img_url: '800x600' }}" 
               alt="Custom Storefront Sign" 
               style="
                 width: 100%;
                 border-radius: 20px;
                 box-shadow: 0 30px 60px rgba(0,0,0,0.4);
               ">
        {% else %}
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&h=600&fit=crop" 
               alt="Premium Illuminated Storefront Sign" 
               style="
                 width: 100%;
                 border-radius: 20px;
                 box-shadow: 0 30px 60px rgba(0,0,0,0.4);
               ">
        {% endif %}
        
        <!-- Floating Cards -->
        <div style="
          position: absolute;
          bottom: 40px;
          left: -50px;
          background: white;
          padding: 22px 28px;
          border-radius: 15px;
          box-shadow: 0 8px 32px rgba(0,0,0,0.16);
          animation: float 3s ease-in-out infinite;
        ">
          <div style="
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #0066CC, #004999);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
            margin-bottom: 10px;
          ">
            <i class="fas fa-clock"></i>
          </div>
          <div>
            <h4 style="font-size: 20px; font-weight: 800; color: #1a1a1a; margin-bottom: 3px;">2 Hours</h4>
            <p style="font-size: 13px; color: #666;">Free Mockup Delivery</p>
          </div>
        </div>
        
        <div style="
          position: absolute;
          top: 40px;
          right: -40px;
          background: white;
          padding: 22px 28px;
          border-radius: 15px;
          box-shadow: 0 8px 32px rgba(0,0,0,0.16);
          animation: float 3s ease-in-out infinite;
          animation-delay: 1.5s;
        ">
          <div style="
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #FF6B35, #ff9a6c);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
            margin-bottom: 10px;
          ">
            <i class="fas fa-truck"></i>
          </div>
          <div>
            <h4 style="font-size: 20px; font-weight: 800; color: #1a1a1a; margin-bottom: 3px;">10-14 Days</h4>
            <p style="font-size: 13px; color: #666;">Fast Production Time</p>
          </div>
        </div>
      </div>
      
    </div>
  </section>

  {% comment %} ===== POPULAR SIGN TYPES SECTION ===== {% endcomment %}
  <section style="padding: 100px 0; background: #f8f9fa;">
    <div style="max-width: 1400px; margin: 0 auto; padding: 0 40px;">
      
