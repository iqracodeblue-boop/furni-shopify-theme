<style>
:root{
  --ts-2xs:.68rem; --ts-xs:.78rem; --ts-sm:.88rem; --ts-base:1rem; --ts-md:1.15rem;
  --ts-lg:1.5rem; --ts-xl:2.2rem; --ts-2xl:clamp(2.4rem,5vw,4.4rem);
  --navy:#111111; --navy-deep:#0a0a0a; --navy-light:#1a1a1a; --gold:#0188CC;
  --gold-deep:#0170a8; --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --red:#0188CC; --red-deep:#016da0; --cream:#ffffff; --cream-deep:#f5f5f5;
  --cream-warm:#fafafa; --ink:#111111; --body:#333333; --muted:#666666;
  --ghost:#999999; --line:rgba(0,0,0,.07); --line2:rgba(0,0,0,.12);
  --line3:rgba(0,0,0,.20); --card:#fff; --white:#fff; --star:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;overflow-x:clip}
@media(max-width:480px){html{font-size:100%}}
body{font-family:var(--fb);background:var(--cream);color:var(--body);-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-x:clip;max-width:100%;position:relative;min-height:100dvh;min-height:-webkit-fill-available;line-height:1.6;}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button{cursor:pointer;border:none;background:none;font-family:inherit}

.page{display:block;min-height:100vh;max-width:100%;overflow-x:clip}

.hero{position:relative;min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;padding:120px 48px 0;overflow:hidden;isolation:isolate;background:linear-gradient(180deg,#080808 0%,#111111 100%);}
.hero-main{flex:1;display:flex;align-items:center;justify-content:center;padding-bottom:48px;}
.hero-bg{position:absolute;inset:0;z-index:-2;background-image:url('https://i.ibb.co/sdnM0Skc/QMva-E.jpg');background-size:cover;background-position:center;filter:brightness(.55) contrast(1.05) saturate(.9);}
.hero-overlay{position:absolute;inset:0;z-index:-1;background:radial-gradient(ellipse 80% 60% at 50% 100%,rgba(0,0,0,.85) 0%,transparent 70%),radial-gradient(ellipse 60% 40% at 80% 20%,rgba(1,136,204,.10) 0%,transparent 60%),linear-gradient(180deg,rgba(5,13,31,.62) 0%,rgba(0,0,0,.78) 100%);}
.hero-inner{max-width:1180px;width:100%;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:center;position:relative;z-index:1;}
@media(max-width:980px){.hero-inner{grid-template-columns:1fr;gap:40px;text-align:center}}
.hero-text{color:#fff}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:var(--fb);font-size:.8rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);padding:8px 14px;border-radius:100px;background:rgba(1,136,204,.10);border:1px solid rgba(1,136,204,.32);margin-bottom:24px;}
.hero h1{font-family:var(--fh);font-size:var(--ts-2xl);line-height:1.02;letter-spacing:-.02em;color:#fff;margin-bottom:18px;font-weight:400;}
.hero h1 em{font-style:italic;color:var(--gold);font-family:var(--fh)}
.hero-tagline{font-family:var(--fh);font-style:italic;font-size:1.18rem;color:var(--gold);margin-bottom:20px;letter-spacing:.005em;}
.hero-desc{font-family:var(--fb);font-size:1.04rem;line-height:1.65;color:rgba(255,255,255,.78);max-width:560px;margin-bottom:38px;}
@media(max-width:980px){.hero-desc{margin:0 auto 32px}}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap}
@media(max-width:980px){.hero-ctas{justify-content:center}}
.btn-primary{background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}
.btn-ghost{background:transparent;color:#fff;font-family:var(--fb);font-size:.95rem;font-weight:600;padding:15px 26px;border-radius:10px;border:1.5px solid rgba(255,255,255,.32);display:inline-flex;align-items:center;gap:10px;transition:background .25s,border-color .25s,transform .2s;}
.btn-ghost:hover{background:rgba(255,255,255,.08);border-color:rgba(1,136,204,.6);transform:translateY(-2px)}
.btn-ghost svg{width:14px;height:14px;stroke:#fff;stroke-width:2;fill:none}

.hero-visual{position:relative;height:100%;display:flex;align-items:center;justify-content:center}
.hero-card{position:relative;width:100%;max-width:520px;aspect-ratio:4/5;border-radius:18px;overflow:hidden;background:#0c0c0c;box-shadow:0 30px 80px rgba(0,0,0,.55),0 0 0 1px rgba(1,136,204,.2);}
.hero-card img{width:100%;height:100%;object-fit:cover;display:block}
.hero-card .hero-slide{position:absolute;inset:0;opacity:0;transition:opacity 1s cubic-bezier(.16,1,.3,1);z-index:0;}
.hero-card .hero-slide.active{opacity:1;z-index:1}
.hero-card::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.85) 100%);z-index:2;pointer-events:none;}
.hero-card-tag{position:absolute;top:18px;left:18px;z-index:3;background:rgba(0,0,0,.75);backdrop-filter:blur(10px);border:1px solid rgba(1,136,204,.4);padding:7px 13px;border-radius:100px;color:var(--gold);font-family:var(--fb);font-size:.7rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px;}
.hero-card-cap{position:absolute;bottom:20px;left:20px;right:20px;z-index:3;color:#fff;font-family:var(--fh);font-size:1.15rem;line-height:1.2;}
.hero-card-cap small{display:block;font-family:var(--fb);font-size:.72rem;font-weight:500;color:rgba(255,255,255,.66);letter-spacing:.06em;margin-top:6px;}
.hero-card-dots{position:absolute;bottom:16px;right:18px;z-index:3;display:flex;gap:7px;}
.hero-card-dots span{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.35);cursor:pointer;transition:background .3s,width .3s;}
.hero-card-dots span.active{background:var(--gold);width:18px;border-radius:4px}

.trust-bar-merged{background:rgba(0,0,0,.55);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-top:1px solid rgba(1,136,204,.22);border-bottom:none;padding:22px 48px;margin:auto -48px 0;position:relative;z-index:2;width:calc(100% + 96px);}
.trust-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:16px;align-items:center;}
.trust-item{display:flex;align-items:center;justify-content:center;gap:10px;color:rgba(255,255,255,.88);font-family:var(--fb);font-size:.82rem;font-weight:500;text-align:left;}
.trust-item svg{width:18px;height:18px;stroke:var(--gold);stroke-width:2;fill:none;flex-shrink:0}
.trust-item strong{color:#fff;font-weight:700;margin-right:3px}

.section{padding:88px 48px;position:relative;overflow:hidden}
.section-alt{background:var(--cream-deep)}
.section-white{background:#fff}
.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;}
.sec-h em{font-style:italic;color:var(--red);font-family:var(--fh)}
.sec-sub{font-family:var(--fb);font-size:1rem;color:var(--muted);line-height:1.65;max-width:580px;margin:0 auto;}

.types-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.type-card{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--line);transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s,border-color .3s;display:flex;flex-direction:column;cursor:pointer;}
.type-card:hover{transform:translateY(-6px);box-shadow:0 24px 48px rgba(0,0,0,.14);border-color:var(--gold-line);}
.type-card-img{position:relative;aspect-ratio:16/10;overflow:hidden;background:var(--navy);}
.type-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s cubic-bezier(.16,1,.3,1);}
.type-card:hover .type-card-img img{transform:scale(1.06)}
.type-badge{position:absolute;top:14px;left:14px;z-index:2;background:var(--red);color:#fff;font-family:var(--fb);font-size:.62rem;font-weight:700;padding:5px 11px;border-radius:100px;letter-spacing:.16em;text-transform:uppercase;box-shadow:0 4px 12px rgba(1,136,204,.32);}
.type-card-body{padding:24px 24px 26px;display:flex;flex-direction:column;flex:1}
.type-card h3{font-family:var(--fh);font-size:1.32rem;color:var(--ink);line-height:1.15;margin-bottom:8px;font-weight:400;letter-spacing:-.01em;}
.type-card p{font-family:var(--fb);font-size:.88rem;color:var(--muted);line-height:1.6;margin-bottom:18px;flex:1;}
.type-card-foot{display:flex;align-items:center;justify-content:flex-start;padding-top:16px;border-top:1px solid var(--line);}
.type-card-link{font-family:var(--fb);font-size:.78rem;font-weight:700;color:var(--navy);display:inline-flex;align-items:center;gap:5px;transition:gap .25s,color .2s;}
.type-card-link:hover{gap:9px;color:var(--red)}
.type-card-link svg{width:12px;height:12px;stroke:currentColor;stroke-width:2.5;fill:none}

.proc-section{position:relative;background:var(--navy-deep);padding:104px 48px;overflow:hidden;}
.proc-section .sec-h{color:#fff}
.proc-section .sec-sub{color:rgba(255,255,255,.55)}
.proc-section .sec-label{color:var(--gold)}
.proc-section .sec-label::before,.proc-section .sec-label::after{background:var(--gold)}
.proc-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:22px;position:relative;z-index:2;}
.proc-step{position:relative;background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:18px;padding:34px 26px 30px;text-align:left;transition:transform .35s cubic-bezier(.16,1,.3,1),border-color .35s,box-shadow .35s;overflow:hidden;}
.proc-step:hover{transform:translateY(-6px);border-color:var(--gold-line);box-shadow:0 24px 50px rgba(0,0,0,.4);}
.proc-step-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;}
.proc-num{font-family:var(--fh);font-size:2.4rem;line-height:1;color:var(--gold);}
.proc-icon{width:50px;height:50px;border-radius:13px;background:var(--gold-soft);border:1px solid var(--gold-line);display:flex;align-items:center;justify-content:center;}
.proc-icon svg{width:23px;height:23px;fill:none;stroke:var(--gold);stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
.proc-step h4{font-family:var(--fh);font-size:1.24rem;color:var(--ink);margin-bottom:9px;font-weight:400;line-height:1.2;}
.proc-step p{font-family:var(--fb);font-size:.88rem;color:var(--muted);line-height:1.62;margin:0;}

.why-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
.why-card{background:#fff;border-radius:14px;padding:32px 26px;border:1px solid var(--line);transition:transform .3s,box-shadow .3s,border-color .3s;position:relative;overflow:hidden;}
.why-card:hover{transform:translateY(-4px);box-shadow:0 18px 36px rgba(0,0,0,.10);border-color:var(--gold-line);}
.why-icon{width:54px;height:54px;border-radius:12px;background:var(--gold-soft);border:1px solid var(--gold-line);display:flex;align-items:center;justify-content:center;margin-bottom:18px;}
.why-icon svg{width:24px;height:24px;stroke:var(--navy);stroke-width:1.8;fill:none}
.why-card h4{font-family:var(--fh);font-size:1.22rem;color:var(--ink);margin-bottom:10px;font-weight:400;line-height:1.2;}
.why-card p{font-family:var(--fb);font-size:.9rem;color:var(--muted);line-height:1.65;}

.gallery-bento{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:200px;gap:14px;}
.gal-item{position:relative;overflow:hidden;border-radius:14px;background:var(--navy);cursor:pointer;transition:transform .3s;}
.gal-item img{width:100%;height:100%;object-fit:cover;transition:transform 1s cubic-bezier(.16,1,.3,1);}
.gal-item:hover img{transform:scale(1.08)}
.gal-item::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.78) 100%);opacity:.85;transition:opacity .3s;}
.gal-cap{position:absolute;left:18px;right:18px;bottom:16px;z-index:2;color:#fff;font-family:var(--fh);font-size:1.05rem;line-height:1.2;transform:translateY(8px);opacity:0;transition:transform .35s,opacity .35s;}
.gal-cap small{display:block;font-family:var(--fb);font-size:.7rem;font-weight:500;color:var(--gold);letter-spacing:.14em;text-transform:uppercase;margin-bottom:4px;}
.gal-item:hover .gal-cap{transform:translateY(0);opacity:1}
.gal-1{grid-column:span 2;grid-row:span 2} .gal-2{grid-column:span 1;grid-row:span 1} .gal-3{grid-column:span 1;grid-row:span 1} .gal-4{grid-column:span 1;grid-row:span 1} .gal-5{grid-column:span 1;grid-row:span 1} .gal-6{grid-column:span 2;grid-row:span 1}

.final-cta{background:linear-gradient(180deg,var(--navy) 0%,var(--navy-deep) 100%);color:#fff;padding:104px 48px;position:relative;overflow:hidden;text-align:center;}
.final-inner{max-width:780px;margin:0 auto;position:relative;z-index:1}
.final-inner .sec-label{color:var(--gold);justify-content:center}
.final-inner .sec-label::before,.final-inner .sec-label::after{background:var(--gold)}
.final-inner h2{font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;line-height:1.04;letter-spacing:-.02em;margin-bottom:18px;font-weight:400;}
.final-inner h2 em{font-style:italic;color:var(--gold)}
.final-inner p{font-family:var(--fb);font-size:1.08rem;line-height:1.6;color:rgba(255,255,255,.72);max-width:560px;margin:0 auto 36px;}

@media(max-width:980px){
  .hero{padding:110px 22px 0}
  .hero-card{max-width:420px;transform:none}
  .trust-bar-merged{margin:auto -22px 0;width:calc(100% + 44px);padding:18px 22px}
  .trust-inner{grid-template-columns:repeat(2,1fr);gap:14px 18px}
  .types-grid{grid-template-columns:repeat(2,1fr);gap:18px}
  .proc-grid{grid-template-columns:repeat(2,1fr);gap:18px}
  .why-grid{grid-template-columns:repeat(2,1fr)}
  .gallery-bento{grid-template-columns:repeat(2,1fr);grid-auto-rows:160px}
  .gal-1{grid-column:span 2;grid-row:span 1}
  .gal-6{grid-column:span 2}
}
@media(max-width:480px){
  .types-grid{grid-template-columns:1fr;gap:16px}
  .proc-grid{grid-template-columns:1fr;gap:16px}
  .why-grid{grid-template-columns:1fr;gap:14px}
  .gallery-bento{grid-template-columns:1fr;grid-auto-rows:200px;gap:10px}
  .gal-1,.gal-6{grid-column:span 1}
}
</style>

