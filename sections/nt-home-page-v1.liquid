                 onmouseover="this.style.transform='scale(1.05)'"
                 onmouseout="this.style.transform='scale(1)'">
            
            <span style="
              position: absolute;
              top: 15px;
              right: 15px;
              background: #FF6B35;
              color: white;
              padding: 6px 14px;
              border-radius: 50px;
              font-size: 11px;
              font-weight: 700;
              text-transform: uppercase;
            ">Most Popular</span>
