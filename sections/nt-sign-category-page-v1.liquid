<style>
:root{
  --ts-2xs:.68rem; --ts-xs:.78rem; --ts-sm:.88rem; --ts-base:1rem; --ts-md:1.15rem;
  --ts-lg:1.5rem; --ts-xl:2.2rem; --ts-2xl:clamp(2.4rem,5vw,4.4rem);
  --navy:#111111; --navy-deep:#0a0a0a; --navy-light:#1a1a1a; --gold:#0188CC;
  --gold-deep:#0170a8; --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --red:#0188CC; --red-deep:#016da0; --cream:#ffffff; --cream-deep:#f5f5f5;
  --cream-warm:#fafafa; --ink:#111111; --body:#333333; --muted:#666666;
  --ghost:#999999; --line:rgba(0,0,0,.07); --line2:rgba(0,0,0,.12);
  --line3:rgba(0,0,0,.20); --card:#fff; --white:#fff; --star:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;overflow-x:clip}
@media(max-width:480px){html{font-size:100%}}
body{font-family:var(--fb);background:var(--cream);color:var(--body);-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-x:clip;max-width:100%;position:relative;min-height:100dvh;min-height:-webkit-fill-available;line-height:1.6;}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button{cursor:pointer;border:none;background:none;font-family:inherit}

/* Category Page Specific CSS */
.cat-page{display:block;min-height:100vh;max-width:100%;overflow-x:clip}

.cat-hero{position:relative;padding:150px 48px 0;background:linear-gradient(180deg,var(--navy-deep) 0%,var(--navy) 100%);color:#fff;overflow:hidden;}
.cat-hero::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 20%,rgba(1,136,204,.12) 0%,transparent 65%),radial-gradient(ellipse 40% 30% at 50% 100%,rgba(1,136,204,.08) 0%,transparent 70%);}
.cat-hero-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.1fr 1fr;gap:64px;align-items:center;position:relative;z-index:1;padding-bottom:80px;}
.cat-breadcrumb{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.74rem;color:rgba(255,255,255,.5);margin-bottom:22px;letter-spacing:.06em;}
.cat-breadcrumb a{color:rgba(255,255,255,.7);transition:color .2s}
.cat-breadcrumb a:hover{color:var(--gold)}
.cat-breadcrumb svg{width:10px;height:10px;stroke:rgba(255,255,255,.4);stroke-width:2.5;fill:none}
.cat-breadcrumb .current{color:var(--gold)}
.cat-hero h1{font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;line-height:1.02;letter-spacing:-.02em;margin-bottom:20px;font-weight:400;}
.cat-hero h1 em{font-style:italic;color:var(--gold)}
.cat-hero-desc{font-family:var(--fb);font-size:1.06rem;line-height:1.7;color:rgba(255,255,255,.78);margin-bottom:28px;max-width:540px;}
.cat-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:34px}
.cat-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(1,136,204,.08);border:1px solid rgba(1,136,204,.32);color:var(--gold);padding:7px 13px;border-radius:100px;font-family:var(--fb);font-size:.78rem;font-weight:600;letter-spacing:.005em;}
.cat-pill svg{width:13px;height:13px;stroke:var(--gold);stroke-width:2.5;fill:none}
.cat-hero-ctas{display:flex;gap:12px;flex-wrap:wrap}
.cat-hero-visual{position:relative;aspect-ratio:4/5;border-radius:18px;overflow:hidden;box-shadow:0 30px 70px rgba(0,0,0,.5),0 0 0 1px rgba(1,136,204,.22);}
.cat-hero-visual img{width:100%;height:100%;object-fit:cover}
.cat-hero-visual::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.6) 100%);}

.trust-bar-merged{background:rgba(0,0,0,.55);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-top:1px solid rgba(1,136,204,.22);border-bottom:none;padding:22px 48px;margin:auto -48px 0;position:relative;z-index:2;width:calc(100% + 96px);}
.trust-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:16px;align-items:center;}
.trust-item{display:flex;align-items:center;justify-content:center;gap:10px;color:rgba(255,255,255,.88);font-family:var(--fb);font-size:.82rem;font-weight:500;letter-spacing:.005em;text-align:left;}
.trust-item svg{width:18px;height:18px;stroke:var(--gold);stroke-width:2;fill:none;flex-shrink:0}
.trust-item strong{color:#fff;font-weight:700;margin-right:3px}

.cat-stats{background:var(--cream-deep);padding:28px 48px;border-bottom:1px solid var(--line2);}
.cat-stats-inner{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.cat-stat{display:flex;align-items:center;gap:14px;}
.cat-stat-icon{width:42px;height:42px;border-radius:10px;background:#fff;border:1px solid var(--gold-line);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cat-stat-icon svg{width:18px;height:18px;stroke:var(--navy);stroke-width:2;fill:none}
.cat-stat-meta{display:flex;flex-direction:column;line-height:1.2}
.cat-stat-num{font-family:var(--fh);font-size:1.32rem;color:var(--ink);font-weight:400}
.cat-stat-lab{font-family:var(--fb);font-size:.74rem;color:var(--muted);margin-top:2px}

.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;}
.sec-h em{font-style:italic;color:var(--red);font-family:var(--fh)}
.sec-sub{font-family:var(--fb);font-size:1rem;color:var(--muted);line-height:1.65;max-width:580px;margin:0 auto;}

.cat-variants{padding:88px 48px;background:#fff}
.cat-var-filters{max-width:1180px;margin:0 auto 32px;display:flex;justify-content:center;gap:8px;flex-wrap:wrap;}
.cat-var-filter{font-family:var(--fb);font-size:.82rem;font-weight:600;color:var(--muted);padding:9px 22px;border-radius:100px;border:1px solid var(--line2);background:#fff;white-space:nowrap;transition:all .25s;cursor:pointer;}
.cat-var-filter:hover{color:var(--ink);border-color:var(--gold-line)}
.cat-var-filter.active{background:var(--gold);color:#fff;border-color:var(--gold);}
.cat-variants-grid .var-card.hidden{display:none}
.cat-variants-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
.var-card{background:#fff;border-radius:14px;overflow:hidden;border:1px solid var(--line);transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .3s,border-color .25s;display:flex;flex-direction:column;}
.var-card:hover{transform:translateY(-5px);box-shadow:0 22px 44px rgba(0,0,0,.12);border-color:var(--gold-line);}
.var-card-img{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--navy);}
.var-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s}
.var-card:hover .var-card-img img{transform:scale(1.06)}
.var-card-body{padding:22px 22px 24px;display:flex;flex-direction:column;flex:1}
.var-card h3{font-family:var(--fh);font-size:1.22rem;color:var(--ink);margin-bottom:7px;font-weight:400;line-height:1.18;}
.var-card p{font-family:var(--fb);font-size:.86rem;color:var(--muted);line-height:1.6;margin-bottom:14px;flex:1;}
.var-tags{display:flex;flex-wrap:wrap;gap:6px}
.var-tag{background:var(--cream);color:var(--body);font-family:var(--fb);font-size:.68rem;font-weight:600;padding:4px 10px;border-radius:100px;border:1px solid var(--line2);}
.var-card-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;}
.var-card-btn{flex:1;min-width:calc(50% - 4px);font-family:var(--fb);font-size:.72rem;font-weight:700;padding:10px 10px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:transform .2s,box-shadow .2s,background .2s,border-color .2s,color .2s;text-align:center;line-height:1.25;letter-spacing:.01em;}
.var-card-btn:not(.var-card-btn-outline){background:var(--gold);color:var(--navy);box-shadow:0 4px 12px rgba(1,136,204,.22);}
.var-card-btn:not(.var-card-btn-outline):hover{background:#02a0eb;transform:translateY(-1px);box-shadow:0 6px 16px rgba(1,136,204,.3);}
.var-card-btn-outline{background:#fff;color:var(--ink);border:1.5px solid var(--line2);}
.var-card-btn-outline:hover{border-color:var(--gold);color:var(--navy);transform:translateY(-1px);}

.cat-specs{padding:88px 48px;background:var(--cream)}
.specs-inner{max-width:980px;margin:0 auto}
.specs-grid{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--line);box-shadow:0 14px 36px rgba(0,0,0,.06);}
.spec-row{display:grid;grid-template-columns:240px 1fr;border-bottom:1px solid var(--line);padding:22px 28px;align-items:center;}
.spec-row:last-child{border-bottom:none}
.spec-label{font-family:var(--fb);font-size:.78rem;font-weight:700;color:var(--navy);letter-spacing:.06em;text-transform:uppercase;}
.spec-val{font-family:var(--fb);font-size:.94rem;color:var(--body);line-height:1.55;}

.cat-portfolio{padding:72px 0;background:var(--navy);overflow:hidden;position:relative}
.cat-portfolio .sec-head{padding:0 48px;margin-bottom:36px}
.cat-portfolio .sec-h{color:#fff}
.cat-portfolio .sec-sub{color:rgba(255,255,255,.5)}
.cat-portfolio .sec-label{color:var(--gold)}
.cat-portfolio .sec-label::before,.cat-portfolio .sec-label::after{background:var(--gold)}
.cat-strip-wrap{position:relative}
.cat-strip-wrap::before,.cat-strip-wrap::after{content:"";position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none;}
.cat-strip-wrap::before{left:0;background:linear-gradient(90deg,var(--navy) 0%,transparent 100%)}
.cat-strip-wrap::after{right:0;background:linear-gradient(270deg,var(--navy) 0%,transparent 100%)}
.cat-strip{display:flex;gap:14px;animation:stripScroll 35s linear infinite;width:max-content;}
.cat-strip:hover{animation-play-state:paused}
@keyframes stripScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.cat-strip-item{flex-shrink:0;width:280px;height:200px;border-radius:12px;overflow:hidden;position:relative;cursor:pointer;}
.cat-strip-item img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.16,1,.3,1);}
.cat-strip-item:hover img{transform:scale(1.08)}
.cat-strip-item::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.65) 100%);opacity:.85;}
.cat-strip-cap{position:absolute;left:14px;right:14px;bottom:12px;z-index:2;color:#fff;font-family:var(--fh);font-size:.95rem;line-height:1.2;}
.cat-strip-cap small{display:block;font-family:var(--fb);font-size:.66rem;font-weight:600;color:var(--gold);letter-spacing:.1em;text-transform:uppercase;margin-bottom:3px;}
.cat-portfolio-link{text-align:center;padding:28px 48px 0}
.cat-portfolio-link a{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.84rem;font-weight:600;color:rgba(255,255,255,.5);transition:color .25s,gap .25s;}
.cat-portfolio-link a:hover{color:var(--gold);gap:12px}
.cat-portfolio-link svg{width:13px;height:13px;stroke:currentColor;stroke-width:2.5;fill:none}

.cat-bestfor{padding:88px 48px;background:#fff}
.bestfor-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}
.bestfor-card{background:var(--cream);padding:28px 22px;border-radius:14px;border:1px solid var(--line);text-align:center;transition:transform .25s,box-shadow .25s;}
.bestfor-card:hover{transform:translateY(-3px);box-shadow:0 16px 32px rgba(0,0,0,.08)}
.bestfor-card-icon{width:50px;height:50px;border-radius:50%;background:var(--gold-soft);border:1px solid var(--gold-line);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.bestfor-card-icon svg{width:22px;height:22px;stroke:var(--navy);stroke-width:1.8;fill:none}
.bestfor-card h4{font-family:var(--fh);font-size:1.05rem;color:var(--ink);margin-bottom:6px;font-weight:400;}
.bestfor-card p{font-family:var(--fb);font-size:.82rem;color:var(--muted);line-height:1.55;}

.final-cta{background:linear-gradient(180deg,var(--navy) 0%,var(--navy-deep) 100%);color:#fff;padding:60px 48px;position:relative;overflow:hidden;text-align:center;}
.final-cta::before{content:"";position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 50% at 0% 100%,rgba(1,136,204,.16) 0%,transparent 70%),radial-gradient(ellipse 60% 50% at 100% 0%,rgba(1,136,204,.10) 0%,transparent 65%);}
.final-inner{max-width:780px;margin:0 auto;position:relative;z-index:1}
.final-inner .sec-label{color:var(--gold);justify-content:center}
.final-inner .sec-label::before,.final-inner .sec-label::after{background:var(--gold)}
.final-inner h2{font-family:var(--fh);font-size:clamp(1.6rem,3.5vw,2.6rem);color:#fff;line-height:1.04;letter-spacing:-.02em;margin-bottom:12px;font-weight:400;}
.final-inner h2 em{font-style:italic;color:var(--gold)}
.final-inner p{font-family:var(--fb);font-size:.96rem;line-height:1.6;color:rgba(255,255,255,.72);max-width:560px;margin:0 auto 28px;}
.final-ctas{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.btn-primary{background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}
.btn-ghost{background:transparent;color:#fff;font-family:var(--fb);font-size:.95rem;font-weight:600;padding:15px 26px;border-radius:10px;border:1.5px solid rgba(255,255,255,.32);display:inline-flex;align-items:center;gap:10px;transition:background .25s,border-color .25s,transform .2s;}
.btn-ghost:hover{background:rgba(255,255,255,.08);border-color:rgba(1,136,204,.6);transform:translateY(-2px)}
.btn-ghost svg{width:14px;height:14px;stroke:#fff;stroke-width:2;fill:none}

@media(max-width:980px){
  .cat-hero{padding:130px 22px 0}
  .cat-hero-inner{grid-template-columns:1fr;gap:36px;padding-bottom:56px}
  .cat-hero-visual{max-width:420px;margin:0 auto;width:100%;aspect-ratio:5/4}
  .trust-bar-merged{margin:auto -22px 0;width:calc(100% + 44px);padding:18px 22px}
  .trust-inner{grid-template-columns:repeat(2,1fr);gap:14px 18px}
  .trust-item{font-size:.76rem;justify-content:flex-start}
  .cat-stats{padding:22px}
  .cat-stats-inner{grid-template-columns:1fr 1fr;gap:18px}
  .cat-stat-num{font-size:1.1rem}
  .cat-variants{padding:64px 22px}
  .cat-var-filters{padding:0 4px;margin-bottom:24px}
  .cat-variants-grid{grid-template-columns:repeat(2,1fr);gap:16px}
  .cat-specs{padding:64px 22px}
  .spec-row{grid-template-columns:1fr;gap:4px;padding:18px 20px}
  .spec-label{font-size:.7rem;color:var(--muted)}
  .cat-portfolio{padding:56px 0}
  .cat-portfolio .sec-head{padding:0 22px;margin-bottom:28px}
  .cat-strip-item{width:240px;height:170px}
  .cat-portfolio-link{padding:22px 22px 0}
  .cat-bestfor{padding:64px 22px}
  .bestfor-grid{grid-template-columns:1fr 1fr;gap:14px}
  .final-cta{padding:46px 22px}
}
@media(max-width:560px){
  .cat-variants-grid{grid-template-columns:1fr}
  .trust-inner{grid-template-columns:1fr;gap:14px;justify-items:center;}
  .trust-item{font-size:.85rem;white-space:normal;line-height:1.4;justify-content:center;text-align:center;}
}
</style>

