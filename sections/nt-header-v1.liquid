<style>
:root{
  --navy:#111111; --navy-deep:#0a0a0a; --gold:#0188CC;
  --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
.nt-nav-wrap{position:fixed;top:0;left:0;right:0;z-index:9999;}
.nt-nav{
  height:calc(72px + env(safe-area-inset-top,0px));
  padding:env(safe-area-inset-top,0px) 48px 0 48px;
  display:flex;align-items:center;justify-content:space-between;
  background:transparent;
  transition:background .4s,border-color .4s,box-shadow .4s,backdrop-filter .4s;
  border-bottom:1px solid transparent;
}
.nt-nav.scrolled{
  background:rgba(0,0,0,.92);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border-bottom-color:rgba(1,136,204,.18);
  box-shadow:0 4px 24px rgba(0,0,0,.18);
}
.nt-nav-logo{display:flex;align-items:center;line-height:1;transition:opacity .25s,transform .25s}
.nt-nav-logo:hover{opacity:.88;transform:translateY(-1px)}
.nt-nav-logo img{height:42px;width:auto;display:block;transition:height .3s;object-fit:contain;}
.nt-nav-menu{display:flex;align-items:center;gap:36px}
.nt-nav-link{
  font-family:var(--fb);font-size:.86rem;font-weight:500;color:#fff;
  letter-spacing:.02em;position:relative;transition:color .25s;
}
.nt-nav-link::after{
  content:"";position:absolute;left:0;bottom:-6px;width:0;height:2px;
  background:var(--gold);transition:width .3s cubic-bezier(.16,1,.3,1);
}
.nt-nav-link:hover{color:#fff}
.nt-nav-link:hover::after{width:100%}

.nt-nav-actions{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.nt-nav-cta{
  background:var(--gold);color:var(--navy);
  font-family:var(--fb);font-size:.85rem;font-weight:700;
  padding:12px 22px;border-radius:8px;letter-spacing:.01em;
  transition:transform .2s,box-shadow .25s,background .25s;
  box-shadow:0 4px 14px rgba(1,136,204,.32);
  display:inline-flex;align-items:center;gap:8px;
  white-space:nowrap;line-height:1;
}
.nt-nav-cta:hover{background:#02a0eb;transform:translateY(-1px);box-shadow:0 8px 22px rgba(1,136,204,.42)}
.nt-nav-cta svg{width:14px;height:14px;stroke:var(--navy);stroke-width:2.5;fill:none;flex-shrink:0}

.nt-nav-burger{
  display:none;flex-direction:column;flex-shrink:0;
  width:40px;height:40px;border-radius:10px;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
  align-items:center;justify-content:center;
}
.nt-nav-burger span{display:block;width:18px;height:2px;background:#fff;border-radius:1px;transition:transform .3s,opacity .3s}
.nt-nav-burger span + span{margin-top:4px}

@media(max-width:980px){
  .nt-nav{
    padding:env(safe-area-inset-top,0px) 16px 0 16px;
    height:calc(64px + env(safe-area-inset-top,0px));
    gap:12px;
  }
  .nt-nav-logo{flex:1;min-width:0}
  .nt-nav-logo img{height:32px;max-width:130px;object-fit:contain;object-position:left center}
  .nt-nav-actions{gap:8px}
  .nt-nav-cta{padding:10px 14px;font-size:.76rem;border-radius:8px}
  .nt-nav-cta svg{width:12px;height:12px}
  .nt-nav-burger{display:flex;width:40px;height:40px}
  .nt-nav-menu{
    position:fixed;
    top:calc(64px + env(safe-area-inset-top,0px));
    left:0;right:0;z-index:650;
    background:rgba(0,0,0,.98);backdrop-filter:blur(20px);
    flex-direction:column;align-items:flex-start;
    padding:28px 24px 32px;gap:20px;
    border-bottom:1px solid rgba(1,136,204,.22);
    opacity:0;visibility:hidden;pointer-events:none;
    transform:translateY(-12px);
    transition:transform .4s cubic-bezier(.16,1,.3,1),opacity .3s,visibility .3s;
  }
  .nt-nav-menu.open{
    opacity:1;visibility:visible;pointer-events:auto;
    transform:translateY(0);
  }
}
</style>

<div class="nt-nav-wrap">
  <nav class="nt-nav" id="ntNav">
    <a href="/" class="nt-nav-logo">
      <img src="https://signs.inc/cdn/shop/files/LOGO_2-removebg-preview.png?v=1720069533&width=250" alt="Signs INC custom business signs logo">
    </a>
    <div class="nt-nav-menu" id="ntNavMenu">
      <a class="nt-nav-link" href="/">Home</a>
      <a class="nt-nav-link" href="/pages/sign-types">Sign Types</a>
      <a class="nt-nav-link" href="/pages/how-it-works">How It Works</a>
      <a class="nt-nav-link" href="/pages/portfolio">Portfolio</a>
      <a class="nt-nav-link" href="/pages/about-us">About Us</a>
      <a class="nt-nav-link" href="/pages/contact-us">Contact</a>
    </div>
    <div class="nt-nav-actions">
      <a href="/pages/get-a-quote" class="nt-nav-cta">
        <span class="nt-nav-cta-long">Get Free Mockup</span>
        <span class="nt-nav-cta-short" style="display:none;">Mockup</span>
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <button class="nt-nav-burger" id="ntNavBurger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const nav = document.getElementById('ntNav');
    const burger = document.getElementById('ntNavBurger');
    const menu = document.getElementById('ntNavMenu');
    
    // Mobile menu toggle
    if (burger && menu) {
      burger.addEventListener('click', () => {
        menu.classList.toggle('open');
      });
    }
    
    // Scrolled background effect
    if (nav) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      });
    }
  });
</script>

