{{ 'recent-blog.css' | asset_url | stylesheet_tag }}

<section class="recent-blog">
  <div class="page-width">

    <div class="blog-header">

      <h2>{{ section.settings.heading }}</h2>

      <a href="{{ section.settings.button_link }}">
        {{ section.settings.button_text }}
      </a>

    </div>

    <div class="blog-grid">

      {% for block in section.blocks %}

      <div class="blog-card" {{ block.shopify_attributes }}>

        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 700 }}"
            alt="{{ block.settings.title }}"
            width="400"
            height="280">
        {% endif %}

        <h3>{{ block.settings.title }}</h3>

        <p>
          by {{ block.settings.author }}
          <span> on {{ block.settings.date }}</span>
        </p>

      </div>

      {% endfor %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Recent Blog",
  "tag": "section",
  "class": "section-recent-blog",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent Blog"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Posts"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "blog",
      "name": "Blog Card",
      "limit": 3,

      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Blog Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Blog Title",
          "default": "First Time Home Owner Ideas"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Kristin Watson"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "Dec 19, 2021"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Recent Blog"
    }
  ]
}
{% endschema %}