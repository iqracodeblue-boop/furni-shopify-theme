<style>
:root{
  --ts-xl:2.2rem; --navy:#111111; --gold:#0188CC; --red:#0188CC;
  --cream:#ffffff; --muted:#666666; --line:rgba(0,0,0,.07);
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%}
body{font-family:var(--fb);background:var(--cream);color:#333;line-height:1.6;}

.factory-section{padding:88px 48px;background:#fff}
.sec-head{text-align:center;max-width:680px;margin:0 auto 56px}
.sec-label{display:inline-flex;align-items:center;gap:8px;font-family:var(--fb);font-size:.82rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.sec-h{font-family:var(--fh);font-size:var(--ts-xl);color:#111;line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;}
.sec-h em{font-style:italic;color:var(--red)}
.sec-sub{font-family:var(--fb);font-size:1rem;color:var(--muted);line-height:1.65;max-width:580px;margin:0 auto;}

.factory-bento{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(12,1fr);grid-auto-rows:180px;gap:14px;}
.fac-item{position:relative;overflow:hidden;border-radius:14px;background:var(--navy);}
.fac-item img{width:100%;height:100%;object-fit:cover;transition:transform .8s}
.fac-item:hover img{transform:scale(1.06)}
.fac-item::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(0,0,0,.7) 100%);opacity:.9;}
.fac-cap{position:absolute;left:18px;right:18px;bottom:16px;z-index:2;}
.fac-cap h4{font-family:var(--fh);font-size:1.1rem;color:#fff;line-height:1.2;margin-bottom:3px;font-weight:400;}
.fac-cap p{font-family:var(--fb);font-size:.74rem;color:rgba(255,255,255,.6);line-height:1.4;}
.fac-1{grid-column:span 7;grid-row:span 2} .fac-2{grid-column:span 5;grid-row:span 1}
.fac-3{grid-column:span 5;grid-row:span 1} .fac-4{grid-column:span 4;grid-row:span 1}
.fac-5{grid-column:span 4;grid-row:span 1} .fac-6{grid-column:span 4;grid-row:span 1}

@media(max-width:880px){
  .factory-bento{grid-template-columns:1fr 1fr;grid-auto-rows:180px}
  .fac-1{grid-column:span 2;grid-row:span 1}
  .fac-2,.fac-3,.fac-4,.fac-5,.fac-6{grid-column:span 1}
}
@media(max-width:480px){.factory-bento{grid-template-columns:1fr;grid-auto-rows:200px}.fac-1{grid-column:span 1}}
</style>

<section class="factory-section">
  <div class="sec-head">
    <span class="sec-label">Inside the Shop</span>
    <h2 class="sec-h">Where Your Sign <em>Gets Built</em></h2>
    <p class="sec-sub">From raw aluminum sheets to illuminated channel letters ready for install. Every step happens under one roof.</p>
  </div>
  <div class="factory-bento">
    <div class="fac-item fac-1"><img src="https://i.ibb.co/wrcCxVkd/1M1T3.jpg" alt="Signs INC factory floor – signs.inc" loading="lazy"><div class="fac-cap"><h4>The Production Floor</h4><p>CNC cutting, welding, painting and LED assembly in one facility.</p></div></div>
    <div class="fac-item fac-2"><img src="https://i.ibb.co/sdnM0Skc/QMva-E.jpg" alt="Signs INC sign workshop – signs.inc" loading="lazy"><div class="fac-cap"><h4>Fabrication</h4><p>Every letter shaped and welded by hand.</p></div></div>
    <div class="fac-item fac-3"><img src="https://i.ibb.co/zhVSVypQ/SKb-Yc.jpg" alt="Skilled hands wiring LED modules – signs.inc" loading="lazy"><div class="fac-cap"><h4>LED Wiring</h4><p>UL-listed modules, hand-wired and tested.</p></div></div>
    <div class="fac-item fac-4"><img src="https://i.ibb.co/60PJ6cmB/SKx-UX.jpg" alt="Quality control inspector testing finished sign – signs.inc" loading="lazy"><div class="fac-cap"><h4>Quality Check</h4><p>Every LED tested before crating.</p></div></div>
    <div class="fac-item fac-5"><img src="https://i.ibb.co/Mx6wcX3j/t8Qne.jpg" alt="Custom business signs crated for shipping – signs.inc" loading="lazy"><div class="fac-cap"><h4>Crating &amp; Shipping</h4><p>Foam-packed, strapped and freight-ready.</p></div></div>
    <div class="fac-item fac-6"><img src="https://i.ibb.co/Zz4HctKC/WTzqu.jpg" alt="Installer mounting custom illuminated channel letters – signs.inc" loading="lazy"><div class="fac-cap"><h4>Installation</h4><p>Certified crews in all 50 states.</p></div></div>
  </div>
</section>

{% schema %}
{
  "name": "NT About Factory",
  "presets": [
    {
      "name": "NT About Factory"
    }
  ]
}
{% endschema %}