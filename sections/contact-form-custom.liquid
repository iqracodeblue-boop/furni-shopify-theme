{{ 'contact-form-custom.css' | asset_url | stylesheet_tag }}

<section class="contact-custom">
  <div class="page-width">

    <div class="contact-info-row">

      <div class="info-box">
        <div class="icon">📍</div>
        <p>43 Raymouth Rd. Baltemoer,<br>London 3910</p>
      </div>

      <div class="info-box">
        <div class="icon">✉</div>
        <p>info@yourdomain.com</p>
      </div>

      <div class="info-box">
        <div class="icon">☎</div>
        <p>+1 294 3925 3939</p>
      </div>

    </div>

    {% form 'contact' %}

      <div class="row">
        <div class="field">
          <label>First name</label>
          <input type="text" name="contact[first_name]">
        </div>

        <div class="field">
          <label>Last name</label>
          <input type="text" name="contact[last_name]">
        </div>
      </div>

      <div class="field">
        <label>Email address</label>
        <input type="email" name="contact[email]" required>
      </div>

      <div class="field">
        <label>Message</label>
        <textarea name="contact[body]" rows="7"></textarea>
      </div>

      <button class="send-btn" type="submit">
        Send Message
      </button>

    {% endform %}

  </div>
</section>