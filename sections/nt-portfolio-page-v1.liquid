<style>
:root{
  --ts-2xs:.68rem; --ts-xs:.78rem; --ts-sm:.88rem; --ts-base:1rem; --ts-md:1.15rem;
  --ts-lg:1.5rem; --ts-xl:2.2rem; --ts-2xl:clamp(2.4rem,5vw,4.4rem);
  --navy:#111111; --navy-deep:#0a0a0a; --navy-light:#1a1a1a; --gold:#0188CC;
  --gold-deep:#0170a8; --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --red:#0188CC; --red-deep:#016da0; --cream:#ffffff; --cream-deep:#f5f5f5;
  --cream-warm:#fafafa; --ink:#111111; --body:#333333; --muted:#666666;
  --ghost:#999999; --line:rgba(0,0,0,.07); --line2:rgba(0,0,0,.12);
  --line3:rgba(0,0,0,.20); --card:#fff; --white:#fff; --star:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;overflow-x:clip}
@media(max-width:480px){html{font-size:100%}}
body{font-family:var(--fb);background:var(--cream);color:var(--body);-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-x:clip;max-width:100%;position:relative;min-height:100dvh;min-height:-webkit-fill-available;line-height:1.6;}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button{cursor:pointer;border:none;background:none;font-family:inherit}

/* Portfolio Page Specific CSS */
.page{display:block;min-height:100vh;max-width:100%;overflow-x:clip}

.port-hero{
  position:relative;padding:150px 48px 70px;
  background:linear-gradient(180deg,var(--navy-deep) 0%,var(--navy) 100%);
  color:#fff;text-align:center;overflow:hidden;
}
.port-hero::before{
  content:"";position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 50% at 50% 30%,rgba(1,136,204,.14) 0%,transparent 65%);
}
.port-hero-inner{max-width:720px;margin:0 auto;position:relative;z-index:1}
.sec-label{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--fb);font-size:.82rem;font-weight:700;
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--red);margin-bottom:16px;
}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.port-hero h1{
  font-family:var(--fh);font-size:var(--ts-2xl);color:#fff;
  line-height:1.04;letter-spacing:-.02em;margin-bottom:16px;font-weight:400;
}
.port-hero h1 em{font-style:italic;color:var(--gold)}
.port-hero p{
  font-family:var(--fb);font-size:1.06rem;line-height:1.65;
  color:rgba(255,255,255,.65);max-width:560px;margin:0 auto;
}

.port-filters{
  padding:0 48px;background:#fff;border-bottom:1px solid var(--line);
  position:sticky;top:72px;z-index:500;
}
.port-filters-inner{
  max-width:1280px;margin:0 auto;display:flex;align-items:center;gap:6px;
  padding:14px 0;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;
}
.port-filters-inner::-webkit-scrollbar{display:none}
.port-filter{
  font-family:var(--fb);font-size:.82rem;font-weight:600;
  color:var(--muted);padding:9px 18px;border-radius:100px;
  border:1px solid var(--line2);background:#fff;white-space:nowrap;
  transition:all .25s;cursor:pointer;
}
.port-filter:hover{color:var(--ink);border-color:var(--gold-line)}
.port-filter.active{background:var(--gold);color:#fff;border-color:var(--gold);}

.port-grid-wrap{padding:48px 48px 88px;background:var(--cream)}
.port-grid{
  max-width:1280px;margin:0 auto;
  display:grid;grid-template-columns:repeat(3,1fr);gap:20px;
}
.port-item{
  background:#fff;border-radius:14px;overflow:hidden;
  border:1px solid var(--line);
  transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .3s,border-color .25s;
  display:flex;flex-direction:column;
}
.port-item.hidden{display:none}
.port-item:hover{transform:translateY(-5px);box-shadow:0 22px 44px rgba(0,0,0,.09);border-color:var(--gold-line);}
.port-item-img{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--navy);}
.port-item-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s cubic-bezier(.16,1,.3,1);}
.port-item:hover .port-item-img img{transform:scale(1.05)}
.port-item-tag{
  position:absolute;top:12px;left:12px;z-index:2;
  background:rgba(0,0,0,.55);backdrop-filter:blur(8px);color:#fff;
  font-family:var(--fb);font-size:.64rem;font-weight:700;padding:5px 11px;border-radius:100px;
  letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(255,255,255,.15);
}
.port-item-body{padding:20px 20px 22px}
.port-item h3{
  font-family:var(--fh);font-size:1.12rem;color:var(--ink);
  line-height:1.2;margin-bottom:5px;font-weight:400;
}
.port-item p{font-family:var(--fb);font-size:.82rem;color:var(--muted);line-height:1.55;}
.port-item-loc{
  font-family:var(--fb);font-size:.7rem;color:var(--gold);font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;margin-top:10px;
  display:inline-flex;align-items:center;gap:5px;
}
.port-item-loc svg{width:11px;height:11px;stroke:var(--gold);stroke-width:2.5;fill:none}

.port-count{
  text-align:center;padding:20px;font-family:var(--fb);font-size:.82rem;color:var(--muted);
  max-width:1280px;margin:0 auto;
}
.port-count strong{color:var(--ink)}

.final-cta{
  background:linear-gradient(180deg,var(--navy) 0%,var(--navy-deep) 100%);
  color:#fff;padding:64px 48px;position:relative;overflow:hidden;text-align:center;
}
.final-cta::before{content:"";position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 50% at 0% 100%,rgba(1,136,204,.16) 0%,transparent 70%),radial-gradient(ellipse 60% 50% at 100% 0%,rgba(1,136,204,.10) 0%,transparent 65%);}
.final-inner{max-width:780px;margin:0 auto;position:relative;z-index:1}
.final-inner .sec-label{color:var(--gold);justify-content:center}
.final-inner .sec-label::before,.final-inner .sec-label::after{background:var(--gold)}
.final-inner h2{font-family:var(--fh);font-size:clamp(1.6rem,3.5vw,2.6rem);color:#fff;line-height:1.04;letter-spacing:-.02em;margin-bottom:12px;font-weight:400;}
.final-inner h2 em{font-style:italic;color:var(--gold)}
.final-inner p{font-family:var(--fb);font-size:.96rem;line-height:1.6;color:rgba(255,255,255,.72);max-width:560px;margin:0 auto 28px;}
.btn-primary{background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}

@media(max-width:980px){
  .port-hero{padding:130px 22px 56px}
  .port-filters{padding:0 22px;top:64px}
  .port-grid-wrap{padding:36px 22px 64px}
  .port-grid{grid-template-columns:repeat(2,1fr);gap:16px}
}
@media(max-width:560px){
  .port-grid{grid-template-columns:1fr}
  .port-filter{font-size:.76rem;padding:8px 14px}
}
</style>

