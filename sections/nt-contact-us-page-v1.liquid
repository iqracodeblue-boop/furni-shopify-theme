<style>
:root{
  --ts-2xs:.68rem; --ts-xs:.78rem; --ts-sm:.88rem; --ts-base:1rem; --ts-md:1.15rem;
  --ts-lg:1.5rem; --ts-xl:2.2rem; --ts-2xl:clamp(2.4rem,5vw,4.4rem);
  --navy:#111111; --navy-deep:#0a0a0a; --navy-light:#1a1a1a; --gold:#0188CC;
  --gold-deep:#0170a8; --gold-soft:rgba(1,136,204,.10); --gold-line:rgba(1,136,204,.24);
  --red:#0188CC; --red-deep:#016da0; --cream:#ffffff; --cream-deep:#f5f5f5;
  --cream-warm:#fafafa; --ink:#111111; --body:#333333; --muted:#666666;
  --ghost:#999999; --line:rgba(0,0,0,.07); --line2:rgba(0,0,0,.12);
  --line3:rgba(0,0,0,.20); --card:#fff; --white:#fff; --star:#0188CC;
  --fh:'DM Serif Display',Georgia,serif; --fb:'Inter',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:93%;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;overflow-x:clip}
@media(max-width:480px){html{font-size:100%}}
body{font-family:var(--fb);background:var(--cream);color:var(--body);-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-x:clip;max-width:100%;position:relative;min-height:100dvh;min-height:-webkit-fill-available;line-height:1.6;}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button{cursor:pointer;border:none;background:none;font-family:inherit}

/* Contact Page Specific CSS */
.page{display:block;min-height:100vh;max-width:100%;overflow-x:clip}

.contact-hero{
  position:relative;padding:130px 48px 0;
  background:linear-gradient(160deg,#0a0a0a 0%,#111 55%,#0d1a26 100%);
  color:#fff;text-align:center;overflow:hidden;
}
.contact-hero::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 60% at 50% 20%,rgba(1,136,204,.18) 0%,transparent 60%),radial-gradient(ellipse 40% 50% at 5% 80%,rgba(1,136,204,.10) 0%,transparent 55%),radial-gradient(ellipse 35% 45% at 95% 70%,rgba(1,136,204,.08) 0%,transparent 55%);
}
.contact-hero::after{
  content:"";position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size:52px 52px;
  mask-image:radial-gradient(ellipse 80% 70% at 50% 30%,#000 20%,transparent 72%);
  -webkit-mask-image:radial-gradient(ellipse 80% 70% at 50% 30%,#000 20%,transparent 72%);
}
.contact-hero-inner{max-width:720px;margin:0 auto;position:relative;z-index:1;padding-bottom:52px}
.contact-hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(1,136,204,.12);border:1px solid rgba(1,136,204,.3);
  border-radius:100px;padding:6px 16px 6px 10px;
  font-family:var(--fb);font-size:.76rem;font-weight:600;
  color:var(--gold);letter-spacing:.04em;text-transform:uppercase;
  margin-bottom:24px;
}
.contact-hero-badge-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);animation:pulse 1.8s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}
.contact-hero h1{
  font-family:var(--fh);font-size:clamp(2.2rem,5vw,3.6rem);color:#fff;
  line-height:1.04;letter-spacing:-.025em;margin-bottom:18px;font-weight:400;
}
.contact-hero h1 em{font-style:italic;color:var(--gold)}
.contact-hero-sub{
  font-family:var(--fb);font-size:1.05rem;line-height:1.7;
  color:rgba(255,255,255,.6);max-width:540px;margin:0 auto 36px;
}
.contact-hero-trust{
  display:flex;align-items:center;justify-content:center;gap:28px;
  flex-wrap:wrap;margin-bottom:0;
}
.contact-hero-trust-item{
  display:flex;align-items:center;gap:7px;
  font-family:var(--fb);font-size:.82rem;color:rgba(255,255,255,.55);
}
.contact-hero-trust-item svg{width:14px;height:14px;fill:none;stroke:var(--gold);stroke-width:2.2}
.contact-hero-trust-item strong{color:rgba(255,255,255,.9)}

.contact-info-bar{
  position:relative;z-index:2;
  background:rgba(255,255,255,.04);
  border-top:1px solid rgba(255,255,255,.08);
  padding:0 48px;margin:0 -48px;width:calc(100% + 96px);
}
.contact-info-bar-inner{
  max-width:1100px;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);
}
.contact-info-item{
  display:flex;align-items:center;gap:14px;
  padding:24px 20px;
  border-right:1px solid rgba(255,255,255,.08);
  transition:background .22s;
}
.contact-info-item:last-child{border-right:none}
.contact-info-item:hover{background:rgba(255,255,255,.04)}
.contact-info-icon{
  width:40px;height:40px;border-radius:10px;flex-shrink:0;
  background:rgba(1,136,204,.12);border:1px solid rgba(1,136,204,.25);
  display:flex;align-items:center;justify-content:center;
}
.contact-info-icon svg{width:17px;height:17px;fill:none;stroke:var(--gold);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.contact-info-text strong{display:block;font-family:var(--fb);font-size:.84rem;color:#fff;font-weight:600;margin-bottom:2px}
.contact-info-text span{font-family:var(--fb);font-size:.78rem;color:rgba(255,255,255,.5);line-height:1.4}
.contact-info-text a{color:var(--gold);font-weight:600;font-size:.84rem;transition:color .2s}
.contact-info-text a:hover{color:#fff}

.contact-form-section{
  padding:72px 48px 80px;
  background:linear-gradient(160deg,#eff2f5 0%,#e8ecf0 100%);
  position:relative;
}
.contact-form-section::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background-image:radial-gradient(ellipse 60% 50% at 100% 0%,rgba(1,136,204,.06) 0%,transparent 60%),radial-gradient(ellipse 40% 40% at 0% 100%,rgba(1,136,204,.04) 0%,transparent 55%);
}
.contact-form-wrap{
  max-width:1100px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1.2fr;gap:48px;
  align-items:start;position:relative;z-index:1;
}

.contact-form-left .sec-label{justify-content:flex-start}
.sec-label{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--fb);font-size:.82rem;font-weight:700;
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--red);margin-bottom:16px;
}
.sec-label::before{content:"";width:24px;height:1px;background:var(--red);}
.sec-label::after{content:"";width:24px;height:1px;background:var(--red);}
.contact-form-left .sec-label::before,.contact-form-left .sec-label::after{display:none}
.contact-form-left .sec-h{text-align:left;margin-bottom:10px}
.sec-h{
  font-family:var(--fh);font-size:var(--ts-xl);color:var(--ink);
  line-height:1.05;letter-spacing:-.02em;margin-bottom:14px;font-weight:400;
}
.sec-h em{font-style:italic;color:var(--red);font-family:var(--fh)}
.contact-form-left>p{font-family:var(--fb);font-size:.95rem;color:var(--body);line-height:1.7;margin-bottom:28px;}

.contact-tab-nav{display:flex;flex-direction:column;gap:6px;margin-bottom:28px;}
.contact-tab-btn{
  display:flex;align-items:center;gap:12px;
  padding:13px 16px;border-radius:12px;
  border:1.5px solid transparent;background:transparent;
  cursor:pointer;text-align:left;width:100%;
  transition:all .22s cubic-bezier(.16,1,.3,1);
}
.contact-tab-btn:hover{background:#fff;border-color:var(--line)}
.contact-tab-btn.active{background:#fff;border-color:var(--gold-line);box-shadow:0 4px 16px rgba(1,136,204,.10);}
.contact-tab-icon{
  width:38px;height:38px;border-radius:10px;flex-shrink:0;
  background:var(--cream-deep);border:1px solid var(--line);
  display:flex;align-items:center;justify-content:center;transition:all .22s;
}
.contact-tab-icon svg{width:16px;height:16px;fill:none;stroke:var(--muted);stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round;transition:stroke .22s}
.contact-tab-btn.active .contact-tab-icon,.contact-tab-btn:hover .contact-tab-icon{background:var(--gold-soft);border-color:var(--gold-line)}
.contact-tab-btn.active .contact-tab-icon svg,.contact-tab-btn:hover .contact-tab-icon svg{stroke:var(--gold)}
.contact-tab-text strong{display:block;font-family:var(--fb);font-size:.88rem;color:var(--ink);font-weight:600;margin-bottom:1px}
.contact-tab-text span{font-family:var(--fb);font-size:.78rem;color:var(--muted);line-height:1.4}
.contact-tab-btn.active .contact-tab-text strong{color:var(--gold)}
.contact-tab-arrow{margin-left:auto;flex-shrink:0;width:20px;height:20px;border-radius:50%;background:transparent;display:flex;align-items:center;justify-content:center;transition:background .22s,transform .22s;}
.contact-tab-arrow svg{width:12px;height:12px;fill:none;stroke:var(--muted);stroke-width:2.5;stroke-linecap:round;transition:stroke .22s}
.contact-tab-btn.active .contact-tab-arrow{background:var(--gold-soft);transform:translateX(2px)}
.contact-tab-btn.active .contact-tab-arrow svg{stroke:var(--gold)}

.contact-tab-blurb{
  background:#fff;border:1px solid var(--gold-line);border-radius:12px;
  padding:16px 18px;font-family:var(--fb);font-size:.86rem;color:var(--body);line-height:1.6;
  animation:fadeDown .28s ease;border-left:3px solid var(--gold);
}

.contact-form-right{
  background:#fff;border-radius:20px;padding:36px 32px;
  border:1px solid rgba(0,0,0,.06);
  box-shadow:0 2px 0 0 rgba(1,136,204,.18),0 8px 24px rgba(0,0,0,.07),0 24px 56px rgba(0,0,0,.10),0 48px 80px rgba(0,0,0,.06);
  position:relative;
}
.contact-form-right::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold) 0%,rgba(1,136,204,.3) 60%,transparent 100%);
  border-radius:20px 20px 0 0;
}

.qf-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.qf-field{display:flex;flex-direction:column}
.qf-field.full{grid-column:span 2}
.qf-label{font-family:var(--fb);font-size:.74rem;font-weight:700;color:var(--ink);letter-spacing:.06em;text-transform:uppercase;margin-bottom:7px;}
.qf-label .req{color:var(--red)}
.qf-input,.qf-textarea{
  font-family:var(--fb);font-size:.92rem;padding:13px 14px;border-radius:9px;
  border:1.5px solid var(--line2);background:var(--cream);color:var(--ink);
  transition:border-color .2s,background .2s,box-shadow .2s;width:100%;outline:none;
}
.qf-input:focus,.qf-textarea:focus{border-color:var(--gold);background:#fff;box-shadow:0 0 0 4px rgba(1,136,204,.14);}
.qf-textarea{resize:vertical;min-height:90px;font-family:var(--fb)}
.qf-submit{
  width:100%;background:var(--navy);color:#fff;font-family:var(--fb);font-size:.95rem;font-weight:700;
  padding:16px;border-radius:10px;margin-top:6px;display:inline-flex;align-items:center;justify-content:center;gap:10px;
  transition:background .25s,transform .2s,box-shadow .25s;letter-spacing:.01em;cursor:pointer;
}
.qf-submit:hover{background:var(--navy-deep);transform:translateY(-1px);box-shadow:0 10px 26px rgba(0,0,0,.28)}
.qf-submit svg{width:16px;height:16px;stroke:#fff;stroke-width:2.5;fill:none}
.qf-note{font-family:var(--fb);font-size:.72rem;color:var(--muted);text-align:center;margin-top:14px;line-height:1.5;}
.qf-note svg{width:11px;height:11px;stroke:var(--gold);stroke-width:2;fill:none;display:inline-block;vertical-align:-1px;margin-right:3px}

.contact-mockup-cta{background:var(--navy-deep);padding:64px 48px;position:relative;overflow:hidden;}
.contact-mockup-cta::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 55% 100% at 0% 100%,rgba(1,136,204,.2) 0%,transparent 55%),radial-gradient(ellipse 40% 80% at 100% 0%,rgba(1,136,204,.1) 0%,transparent 55%);}
.contact-mockup-cta-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;position:relative;z-index:1;}
.contact-mockup-cta-text .sec-label{justify-content:flex-start;margin-bottom:10px;color:var(--gold)}
.contact-mockup-cta-text .sec-label::before,.contact-mockup-cta-text .sec-label::after{background:var(--gold)}
.contact-mockup-cta-text h3{font-family:var(--fh);font-size:clamp(1.6rem,3vw,2.3rem);color:#fff;font-weight:400;margin-bottom:12px;line-height:1.12;}
.contact-mockup-cta-text h3 em{font-style:italic;color:var(--gold)}
.contact-mockup-cta-text p{font-family:var(--fb);font-size:.93rem;color:rgba(255,255,255,.58);line-height:1.65;max-width:480px;}
.contact-mockup-actions{display:flex;flex-direction:column;align-items:center;gap:16px;}
.btn-primary{
  background:var(--gold);color:var(--navy);font-family:var(--fb);font-size:.95rem;font-weight:700;
  padding:16px 28px;border-radius:10px;display:inline-flex;align-items:center;gap:10px;
  transition:transform .2s,box-shadow .25s,background .25s;box-shadow:0 8px 24px rgba(1,136,204,.32);letter-spacing:.005em;
}
.btn-primary:hover{background:#02a0eb;transform:translateY(-2px);box-shadow:0 14px 32px rgba(1,136,204,.42)}
.btn-primary svg{width:16px;height:16px;stroke:var(--navy);stroke-width:2.5;fill:none;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}

@media(max-width:1024px){
  .contact-form-wrap{grid-template-columns:1fr;gap:0;}
  .contact-form-right{order:-1}
  .contact-form-left{order:1;margin-top:40px}
  .contact-tab-nav{flex-direction:row;flex-wrap:wrap;gap:8px}
  .contact-tab-btn{flex:1;min-width:calc(50% - 4px)}
  .contact-tab-arrow{display:none}
  .contact-info-bar-inner{grid-template-columns:repeat(2,1fr)}
  .contact-info-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.08);padding:18px 16px}
  .contact-info-item:nth-child(even){border-left:1px solid rgba(255,255,255,.08)}
  .contact-info-item:last-child{border-bottom:none}
  .contact-info-item:nth-last-child(2):nth-child(odd){border-bottom:none}
}
@media(max-width:768px){
  .contact-hero{padding:90px 20px 0}
  .contact-hero-inner{padding-bottom:36px}
  .contact-info-bar{margin:0 -20px;width:calc(100% + 40px);padding:0 20px}
  .contact-hero-trust{display:none}
  .contact-info-bar{padding:0}
  .contact-info-bar-inner{grid-template-columns:1fr 1fr}
  .contact-info-item{padding:14px 12px}
  .contact-info-item:nth-child(3),.contact-info-item:nth-child(4){display:none}
  .contact-info-item:nth-child(even){border-left:none}
  .contact-info-item:nth-child(1){border-right:1px solid rgba(255,255,255,.08)}
  .contact-info-item:nth-child(2){border-left:none}
  .contact-info-item{border-bottom:none}
  .contact-form-section{padding:28px 16px 48px}
  .contact-form-wrap{gap:0}
  .contact-form-right{padding:22px 16px 24px;border-radius:16px;box-shadow:0 2px 0 0 rgba(1,136,204,.18),0 8px 32px rgba(0,0,0,.10),0 24px 48px rgba(0,0,0,.08);}
  .contact-form-left{display:none}
  .contact-form-right .qf-row{grid-template-columns:1fr;gap:0}
  .contact-form-right .qf-field{width:100%}
  .qf-input,.qf-textarea{font-size:.95rem;padding:11px 13px}
  .qf-label{font-size:.74rem}
  .qf-submit{width:100%;justify-content:center;padding:15px 20px;font-size:.95rem}
  .qf-note{justify-content:center;text-align:center}
  .contact-mockup-cta{padding:40px 20px}
  .contact-mockup-cta-inner{grid-template-columns:1fr;gap:20px}
  .contact-mockup-cta-text h3{font-size:1.5rem}
  .contact-mockup-cta-text p{font-size:.86rem}
  .contact-mockup-actions{align-items:flex-start}
  .contact-mockup-btn{width:100%;justify-content:center}
}
</style>

<!-- CONTACT PAGE HTML -->
