  <section class="contact-form-section">
    <div class="contact-form-wrap">

      <div class="contact-form-left">
        <span class="sec-label">Contact Us</span>
        <h2 class="sec-h">How Can We <em>Help You?</em></h2>
        <p>Pick the topic that best fits and we will route your message to the right person. Every inquiry gets a real response.</p>

        <nav class="contact-tab-nav" id="contactTabNav">
          <button type="button" class="contact-tab-btn active" data-tab="general">
