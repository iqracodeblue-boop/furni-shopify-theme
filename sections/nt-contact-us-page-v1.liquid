{{ 'nt-signs-styles.css' | asset_url | stylesheet_tag }}
<!-- ───────── CONTACT PAGE ───────── -->
<main id="page-contact" class="page">

  <!-- HERO -->
  <section class="contact-hero">
    <div class="contact-hero-inner">
      <div class="contact-hero-badge">
        <span class="contact-hero-badge-dot"></span>
        Typically responds in under 2 hours
      </div>
      <h1>We&rsquo;re Here to <em>Help.</em></h1>
      <p class="contact-hero-sub">Whether you have a project in mind, a question about an order, a partnership idea, or just want to know what&rsquo;s possible — our team is ready.</p>
      <div class="contact-hero-trust">
        <div class="contact-hero-trust-item">
          <svg viewBox="0 0 24 24"><path d="M12 2l3 7h7l-6 4.5L18 22l-6-4-6 4 2-8.5L2 9h7z"/></svg>
          <strong>4.9/5</strong><span>from 450+ businesses</span>
        </div>
        <div class="contact-hero-trust-item">
          <svg viewBox="0 0 24 24"><path d="M20 7L9 18l-5-5"/></svg>
          <strong>Free mockup</strong><span>no commitment</span>
        </div>
        <div class="contact-hero-trust-item">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <strong>All 50 states</strong><span>served</span>
        </div>
      </div>
    </div>

    <!-- INFO BAR -->
    <div class="contact-info-bar">
      <div class="contact-info-bar-inner">
        <div class="contact-info-item">
          <span class="contact-info-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg></span>
          <div class="contact-info-text">
            <strong>Call Us</strong>
            <a href="tel:+12059007525">+1 205 900 7525</a>
          </div>
        </div>
        <div class="contact-info-item">
          <span class="contact-info-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
          <div class="contact-info-text">
            <strong>Email Us</strong>
            <a href="mailto:hello@signs.inc">hello@signs.inc</a>
          </div>
        </div>
        <div class="contact-info-item">
          <span class="contact-info-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>
          <div class="contact-info-text">
            <strong>Response Time</strong>
            <span>Under 2 hours, Mon&ndash;Fri</span>
          </div>
        </div>
        <div class="contact-info-item">
          <span class="contact-info-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
          <div class="contact-info-text">
            <strong>Service Area</strong>
            <span>All 50 states nationwide</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM + LEFT -->
  <section class="contact-form-section">
    <div class="contact-form-wrap">

      <!-- LEFT: interactive tabs -->
      <div class="contact-form-left">
        <span class="sec-label">Contact Us</span>
        <h2 class="sec-h">How Can We <em>Help You?</em></h2>
        <p>Pick the topic that best fits and we will route your message to the right person. Every inquiry gets a real response.</p>

        <nav class="contact-tab-nav" id="contactTabNav">
          <button type="button" class="contact-tab-btn active" data-tab="general">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></span>
            <span class="contact-tab-text"><strong>General Inquiry</strong><span>Questions about sign types, materials or process</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="mockup">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4 12.5-12.5z"/></svg></span>
            <span class="contact-tab-text"><strong>Request a Mockup</strong><span>Free design on your storefront in 2 hours</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="order">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
            <span class="contact-tab-text"><strong>Order / Support</strong><span>Track production, shipping or fix an issue</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="trade">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
            <span class="contact-tab-text"><strong>Trade &amp; Partnership</strong><span>Volume pricing for contractors &amp; designers</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="warranty">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/></svg></span>
            <span class="contact-tab-text"><strong>Warranty &amp; Returns</strong><span>Issue with a delivered sign? We make it right</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="consultation">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></span>
            <span class="contact-tab-text"><strong>Request a Consultation</strong><span>Book a call with a sign specialist</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="question">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg></span>
            <span class="contact-tab-text"><strong>Ask a Question</strong><span>Quick answer from our team, no commitment</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
        </nav>

        <div class="contact-tab-blurb" id="contactTabBlurb">
          Ask us anything — about sign types, materials, lead times, pricing, permitting, or the process from idea to installation. No question is too small.
        </div>
      </div>

      <!-- RIGHT: form card -->
      <div class="contact-form-right">
        <div class="contact-success" id="contactSuccess">
          <div class="contact-success-icon">
            <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <h4>Message Sent!</h4>
          <p>Thanks for reaching out. A real human will get back to you within 2 business hours.</p>
          <button type="button" class="contact-success-back" id="contactSuccessBack">Send another message</button>
        </div>

        <form class="contact-form-wrap-inner" id="contactForm" onsubmit="event.preventDefault();document.getElementById('contactSuccess').classList.add('visible');this.style.display='none';">
          
          <div class="qf-row">
            <div class="qf-field">
              <label class="qf-label" for="contact-name">Full Name <span class="req">*</span></label>
              <input type="text" id="contact-name" class="qf-input" placeholder="John Carter" required>
            </div>
            <div class="qf-field">
              <label class="qf-label" for="contact-email">Email <span class="req">*</span></label>
              <input type="email" id="contact-email" class="qf-input" placeholder="you@business.com" required>
            </div>
          </div>

          <div class="qf-row">
            <div class="qf-field">
              <label class="qf-label" for="contact-phone">Phone</label>
              <input type="tel" id="contact-phone" class="qf-input" placeholder="(555) 123-4567">
            </div>
            <div class="qf-field">
              <label class="qf-label" for="contact-business">Business Name</label>
              <input type="text" id="contact-business" class="qf-input" placeholder="Your business">
            </div>
          </div>

          <div class="qf-row">
            <div class="qf-field full">
              <label class="qf-label" for="contact-msg">Project Details <span class="req">*</span></label>
              <textarea id="contact-msg" class="qf-textarea" placeholder="Tell us about your project, sign type, or question..." required></textarea>
            </div>
          </div>

          <button type="submit" class="qf-submit">
            Send Message
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
          <p class="qf-note">
            <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/></svg>
            Your information is private. We never sell, share or spam.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- MOCKUP CTA STRIP -->
  <section class="contact-mockup-cta">
    <div class="contact-mockup-cta-inner">
      <div class="contact-mockup-cta-text">
        <span class="sec-label">Free Mockup</span>
        <h3>Prefer to See It First? <em>Get a Free Mockup.</em></h3>
        <p>Send your logo and storefront photo. We will design a custom sign on your building and send it back in 2 hours. No commitment.</p>
      </div>
      <div class="contact-mockup-actions">
        <a href="#" data-page="quote" class="btn-primary contact-mockup-btn">
          Get Your Free Mockup
          <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <span class="contact-mockup-note">
          <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg>
          No obligation · 2-hour turnaround
        </span>
      </div>
    </div>
  </section>

</main>
{% schema %}
{
  "name": "NT Contact Us Page",
  "presets": [
    {
      "name": "NT Contact Us Page"
    }
  ]
}
{% endschema %}