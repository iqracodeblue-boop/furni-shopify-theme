            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="order">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
            <span class="contact-tab-text"><strong>Order / Support</strong><span>Track production, shipping or fix an issue</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="trade">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
            <span class="contact-tab-text"><strong>Trade &amp; Partnership</strong><span>Volume pricing for contractors &amp; designers</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
          <button type="button" class="contact-tab-btn" data-tab="warranty">
            <span class="contact-tab-icon"><svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/></svg></span>
            <span class="contact-tab-text"><strong>Warranty &amp; Returns</strong><span>Issue with a delivered sign? We make it right</span></span>
            <span class="contact-tab-arrow"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></span>
          </button>
        </nav>

        <div class="contact-tab-blurb" id="contactTabBlurb">
          Ask us anything — about sign types, materials, lead times, pricing, permitting, or the process from idea to installation. No question is too small.
        </div>
      </div>

      <div class="contact-form-right">
        <form class="contact-form-wrap-inner" id="contactForm" onsubmit="event.preventDefault();alert('Message Sent! We will get back to you within 2 business hours.');this.reset();">
          
          <div class="qf-row">
            <div class="qf-field">
              <label class="qf-label" for="contact-name">Full Name <span class="req">*</span></label>
              <input type="text" id="contact-name" class="qf-input" placeholder="John Carter" required>
            </div>
            <div class="qf-field">
              <label class="qf-label" for="contact-email">Email <span class="req">*</span></label>
              <input type="email" id="contact-email" class="qf-input" placeholder="you@business.com" required>
            </div>
          </div>

          <div class="qf-row">
            <div class="qf-field">
              <label class="qf-label" for="contact-phone">Phone</label>
              <input type="tel" id="contact-phone" class="qf-input" placeholder="(555) 123-4567">
            </div>
            <div class="qf-field">
              <label class="qf-label" for="contact-business">Business Name</label>
              <input type="text" id="contact-business" class="qf-input" placeholder="Your business">
            </div>
          </div>

          <div class="qf-row">
            <div class="qf-field full">
              <label class="qf-label" for="contact-msg">Project Details <span class="req">*</span></label>
              <textarea id="contact-msg" class="qf-textarea" placeholder="Tell us about your project, sign type, or question..." required></textarea>
            </div>
          </div>

          <button type="submit" class="qf-submit">
            Send Message
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
          <p class="qf-note">
            <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/></svg>
            Your information is private. We never sell, share or spam.
          </p>
        </form>
      </div>
    </div>
  </section>

  <section class="contact-mockup-cta">
    <div class="contact-mockup-cta-inner">
      <div class="contact-mockup-cta-text">
        <span class="sec-label">Free Mockup</span>
        <h3>Prefer to See It First? <em>Get a Free Mockup.</em></h3>
        <p>Send your logo and storefront photo. We will design a custom sign on your building and send it back in 2 hours. No commitment.</p>
      </div>
      <div class="contact-mockup-actions">
        <a href="#" class="btn-primary contact-mockup-btn">
          Get Your Free Mockup
          <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <span class="contact-mockup-note">
          <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg>
          No obligation · 2-hour turnaround
        </span>
      </div>
    </div>
  </section>

</main>

