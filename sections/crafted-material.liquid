{{ 'crafted-material.css' | asset_url | stylesheet_tag }}

<section class="crafted-material">
  <div class="page-width crafted-wrapper">

    <div class="crafted-left">

      <h2>{{ section.settings.heading }}</h2>

      <p>{{ section.settings.description }}</p>

      <a href="{{ section.settings.button_link }}" class="explore-btn">
        {{ section.settings.button_text }}
      </a>

    </div>

    <div class="crafted-products">

      {% for block in section.blocks %}

      <div class="product-card" {{ block.shopify_attributes }}>

        <img
          src="{{ block.settings.image | image_url }}"
          alt="{{ block.settings.title }}"
          width="220"
          height="220">

        <h4>{{ block.settings.title }}</h4>

        <span>{{ block.settings.price }}</span>

        <div class="plus">+</div>

      </div>

      {% endfor %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Crafted Material",
  "tag": "section",
  "class": "section-crafted-material",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted with excellent material."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Donec vitae odio quis nisl dapibus malesuada. Nullam ac aliquet velit. Aliquam vulputate velit imperdiet dolor tempor tristique."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Nordic Chair"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Product Price",
          "default": "$50.00"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Crafted Material",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}